<aside class="fixed left-0 top-0 h-screen w-64 bg-slate-800 dark:bg-slate-950 border-r border-slate-700 dark:border-slate-800 z-40 lg:block hidden">
  <div class="flex flex-col h-full">
    <!-- Logo -->
    <div class="p-6 border-b border-slate-700 dark:border-slate-800">
      <%= link_to root_path, class: "flex items-center gap-3" do %>
        <svg class="fill-current text-primary-500 w-8 h-10" width="32" height="42" viewBox="0 0 32 42" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M7.17241 0C3.2112 0 0 3.2112 0 7.17241V22.0065C0 25.9678 3.2112 29.1789 7.17241 29.1789C11.1336 29.1789 14.3448 25.9678 14.3448 22.0065V7.17241C14.3448 3.2112 11.1336 0 7.17241 0ZM24.8276 0C20.8664 0 17.6552 3.2112 17.6552 7.17241V34.8276C17.6552 38.7888 20.8664 42 24.8276 42C28.7888 42 32 38.7888 32 34.8276V7.17241C32 3.2112 28.7888 0 24.8276 0Z" />
        </svg>
        <div>
          <h1 class="text-white font-bold text-lg">BMS Ops</h1>
          <p class="text-slate-400 text-xs">Infrastructure Management</p>
        </div>
      <% end %>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 p-4 overflow-y-auto">
      <ul class="space-y-1">
        <li>
          <%= link_to root_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(root_path) ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "home", class: "size-5 stroke-current" %>
            <span class="font-medium">Dashboard</span>
          <% end %>
        </li>
        
        <li>
          <%= link_to tenants_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(tenants_path) || current_page?(controller: 'tenants') ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "users", class: "size-5 stroke-current" %>
            <span class="font-medium">Tenants</span>
          <% end %>
        </li>
        
        <li>
          <%= link_to services_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(services_path) || current_page?(controller: 'services') ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "server", class: "size-5 stroke-current" %>
            <span class="font-medium">Services</span>
          <% end %>
        </li>
        
        <li>
          <%= link_to apps_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(apps_path) || current_page?(controller: 'apps') ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "code-bracket", class: "size-5 stroke-current" %>
            <span class="font-medium">Apps</span>
          <% end %>
        </li>
        
        <li>
          <%= link_to databases_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(databases_path) || current_page?(controller: 'databases') ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "circle-stack", class: "size-5 stroke-current" %>
            <span class="font-medium">Databases</span>
          <% end %>
        </li>
        
        <li>
          <%= link_to instances_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(instances_path) || current_page?(controller: 'instances') ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "cube", class: "size-5 stroke-current" %>
            <span class="font-medium">Instances</span>
          <% end %>
        </li>
      </ul>

      <div class="mt-8 pt-8 border-t border-slate-700 dark:border-slate-800">
        <ul class="space-y-1">
          <li>
            <%= link_to "#", class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group" do %>
              <%= icon "cog-6-tooth", class: "size-5 stroke-current" %>
              <span class="font-medium">Settings</span>
            <% end %>
          </li>
          
          <li>
            <%= link_to "#", class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group" do %>
              <%= icon "document-text", class: "size-5 stroke-current" %>
              <span class="font-medium">Documentation</span>
            <% end %>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Footer -->
    <div class="p-4 border-t border-slate-700 dark:border-slate-800">
      <div class="bg-slate-700/50 dark:bg-slate-800/50 rounded-lg p-3">
        <p class="text-xs text-slate-400 mb-1">Environment</p>
        <div class="flex items-center gap-2">
          <span class="size-2 bg-green-500 rounded-full"></span>
          <span class="text-sm font-medium text-slate-200"><%= Rails.env.titleize %></span>
        </div>
      </div>
    </div>
  </div>
</aside>

<!-- Mobile Sidebar Backdrop -->
<div class="lg:hidden fixed inset-0 bg-slate-900/50 z-30 hidden" data-sidebar-target="backdrop" data-action="click->sidebar#close"></div>

<!-- Mobile Sidebar -->
<aside class="lg:hidden fixed left-0 top-0 h-screen w-64 bg-slate-800 dark:bg-slate-950 border-r border-slate-700 dark:border-slate-800 z-40 transform -translate-x-full transition-transform duration-300" data-sidebar-target="drawer">
  <div class="flex flex-col h-full">
    <!-- Logo -->
    <div class="p-6 border-b border-slate-700 dark:border-slate-800 flex items-center justify-between">
      <%= link_to root_path, class: "flex items-center gap-3" do %>
        <svg class="fill-current text-primary-500 w-8 h-10" width="32" height="42" viewBox="0 0 32 42" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M7.17241 0C3.2112 0 0 3.2112 0 7.17241V22.0065C0 25.9678 3.2112 29.1789 7.17241 29.1789C11.1336 29.1789 14.3448 25.9678 14.3448 22.0065V7.17241C14.3448 3.2112 11.1336 0 7.17241 0ZM24.8276 0C20.8664 0 17.6552 3.2112 17.6552 7.17241V34.8276C17.6552 38.7888 20.8664 42 24.8276 42C28.7888 42 32 38.7888 32 34.8276V7.17241C32 3.2112 28.7888 0 24.8276 0Z" />
        </svg>
        <div>
          <h1 class="text-white font-bold text-lg">BMS Ops</h1>
          <p class="text-slate-400 text-xs">Infrastructure Management</p>
        </div>
      <% end %>
      <button type="button" class="text-slate-400 hover:text-white" data-action="click->sidebar#close">
        <%= icon "x-mark", class: "size-6" %>
      </button>
    </div>

    <!-- Navigation (same as desktop) -->
    <nav class="flex-1 p-4 overflow-y-auto">
      <ul class="space-y-1">
        <li>
          <%= link_to root_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(root_path) ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "home", class: "size-5 stroke-current" %>
            <span class="font-medium">Dashboard</span>
          <% end %>
        </li>
        <li>
          <%= link_to tenants_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(tenants_path) || current_page?(controller: 'tenants') ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "users", class: "size-5 stroke-current" %>
            <span class="font-medium">Tenants</span>
          <% end %>
        </li>
        <li>
          <%= link_to services_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(services_path) || current_page?(controller: 'services') ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "server", class: "size-5 stroke-current" %>
            <span class="font-medium">Services</span>
          <% end %>
        </li>
        <li>
          <%= link_to apps_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(apps_path) || current_page?(controller: 'apps') ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "code-bracket", class: "size-5 stroke-current" %>
            <span class="font-medium">Apps</span>
          <% end %>
        </li>
        <li>
          <%= link_to databases_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(databases_path) || current_page?(controller: 'databases') ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "circle-stack", class: "size-5 stroke-current" %>
            <span class="font-medium">Databases</span>
          <% end %>
        </li>
        <li>
          <%= link_to instances_path, class: "flex items-center gap-3 px-4 py-3 text-slate-300 hover:bg-slate-700 dark:hover:bg-slate-800 rounded-lg transition-colors group #{current_page?(instances_path) || current_page?(controller: 'instances') ? 'bg-slate-700 dark:bg-slate-800 text-white' : ''}" do %>
            <%= icon "cube", class: "size-5 stroke-current" %>
            <span class="font-medium">Instances</span>
          <% end %>
        </li>
      </ul>
    </nav>
  </div>
</aside>
