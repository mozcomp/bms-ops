<% if flash.any? %>
  <div class="mb-6 space-y-3">
    <% flash.each do |type, message| %>
      <% if message.present? %>
        <div class="rounded-lg p-4 <%= case type.to_sym
          when :notice then 'bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800'
          when :alert then 'bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800'
          when :warning then 'bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800'
          else 'bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800'
        end %>" data-controller="flash" data-action="click->flash#dismiss">
          <div class="flex items-start gap-3">
            <% case type.to_sym %>
            <% when :notice %>
              <%= icon "check-circle", class: "size-5 text-green-600 dark:text-green-400 flex-shrink-0 mt-0.5" %>
            <% when :alert %>
              <%= icon "exclamation-circle", class: "size-5 text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5" %>
            <% when :warning %>
              <%= icon "exclamation-triangle", class: "size-5 text-yellow-600 dark:text-yellow-400 flex-shrink-0 mt-0.5" %>
            <% else %>
              <%= icon "information-circle", class: "size-5 text-blue-600 dark:text-blue-400 flex-shrink-0 mt-0.5" %>
            <% end %>
            <p class="text-sm flex-1 <%= case type.to_sym
              when :notice then 'text-green-800 dark:text-green-300'
              when :alert then 'text-red-800 dark:text-red-300'
              when :warning then 'text-yellow-800 dark:text-yellow-300'
              else 'text-blue-800 dark:text-blue-300'
            end %>">
              <%= message %>
            </p>
            <button type="button" class="<%= case type.to_sym
              when :notice then 'text-green-600 dark:text-green-400 hover:text-green-800 dark:hover:text-green-300'
              when :alert then 'text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300'
              when :warning then 'text-yellow-600 dark:text-yellow-400 hover:text-yellow-800 dark:hover:text-yellow-300'
              else 'text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300'
            end %>" data-action="click->flash#dismiss">
              <%= icon "x-mark", class: "size-5" %>
            </button>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
