<header class="bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-700 sticky top-0 z-30">
  <div class="px-6 py-4">
    <div class="flex items-center justify-between gap-4">
      <!-- Mobile Menu Button -->
      <button type="button" class="lg:hidden text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white" data-controller="sidebar" data-action="click->sidebar#toggle">
        <%= icon "bars-3", class: "size-6" %>
      </button>

      <!-- Search Bar -->
      <div class="flex-1 max-w-2xl">
        <div class="relative" data-controller="search">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <%= icon "magnifying-glass", class: "size-5 text-slate-400" %>
          </div>
          <input 
            type="text" 
            class="block w-full pl-10 pr-3 py-2 border border-slate-300 dark:border-slate-600 rounded-lg leading-5 bg-white dark:bg-slate-700 text-slate-900 dark:text-slate-100 placeholder-slate-500 dark:placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500 sm:text-sm transition" 
            placeholder="Search tenants, services, apps..." 
            data-search-target="input"
            data-action="keyup->search#filter"
          >
        </div>
      </div>

      <!-- Right Side Actions -->
      <div class="flex items-center gap-4">
        <!-- Notifications -->
        <div class="relative" data-controller="railsui-dropdown">
          <button 
            type="button" 
            class="relative p-2 text-slate-600 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition"
            data-action="click->railsui-dropdown#toggle click@window->railsui-dropdown#hide"
          >
            <%= icon "bell", class: "size-6 stroke-current" %>
            <span class="absolute top-1.5 right-1.5 size-2 bg-red-500 rounded-full"></span>
          </button>

          <!-- Notifications Dropdown -->
          <div 
            class="hidden absolute right-0 mt-2 w-80 bg-white dark:bg-slate-800 rounded-lg shadow-xl border border-slate-200 dark:border-slate-700 py-2 z-50"
            data-railsui-dropdown-target="menu"
            data-transition-enter-active="transition ease-out duration-200"
            data-transition-enter-from="transform opacity-0 scale-95"
            data-transition-enter-to="transform opacity-100 scale-100"
            data-transition-leave-active="transition ease-in duration-150"
            data-transition-leave-from="transform opacity-100 scale-100"
            data-transition-leave-to="transform opacity-0 scale-95"
          >
            <div class="px-4 py-2 border-b border-slate-200 dark:border-slate-700">
              <h3 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Notifications</h3>
            </div>
            <div class="max-h-96 overflow-y-auto">
              <% [
                { title: "New tenant onboarded", message: "Acme Corp production environment is ready", time: "5 mins ago", type: "success" },
                { title: "Service deployment complete", message: "BMS Core API v2.4.1 deployed successfully", time: "1 hour ago", type: "info" },
                { title: "Database migration pending", message: "Tenant schema requires migration", time: "3 hours ago", type: "warning" }
              ].each do |notification| %>
                <a href="#" class="block px-4 py-3 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition">
                  <div class="flex gap-3">
                    <div class="flex-shrink-0">
                      <% case notification[:type] %>
                      <% when "success" %>
                        <div class="size-8 bg-green-100 dark:bg-green-900/30 rounded-full flex items-center justify-center">
                          <%= icon "check-circle", class: "size-4 text-green-600 dark:text-green-400" %>
                        </div>
                      <% when "warning" %>
                        <div class="size-8 bg-yellow-100 dark:bg-yellow-900/30 rounded-full flex items-center justify-center">
                          <%= icon "exclamation-triangle", class: "size-4 text-yellow-600 dark:text-yellow-400" %>
                        </div>
                      <% else %>
                        <div class="size-8 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center">
                          <%= icon "information-circle", class: "size-4 text-blue-600 dark:text-blue-400" %>
                        </div>
                      <% end %>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-slate-900 dark:text-slate-100"><%= notification[:title] %></p>
                      <p class="text-sm text-slate-600 dark:text-slate-400 truncate"><%= notification[:message] %></p>
                      <p class="text-xs text-slate-500 dark:text-slate-500 mt-1"><%= notification[:time] %></p>
                    </div>
                  </div>
                </a>
              <% end %>
            </div>
            <div class="px-4 py-2 border-t border-slate-200 dark:border-slate-700">
              <%= link_to "View all notifications", "#", class: "text-sm font-medium text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300" %>
            </div>
          </div>
        </div>

        <!-- User Menu -->
        <div class="relative" data-controller="railsui-dropdown">
          <button 
            type="button"
            class="flex items-center gap-3 p-1.5 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition"
            data-action="click->railsui-dropdown#toggle click@window->railsui-dropdown#hide"
          >
            <%= image_tag demo_avatar_url(id: "42"), class: "size-8 rounded-full border-2 border-slate-200 dark:border-slate-600", alt: "Admin User" %>
            <div class="hidden sm:block text-left">
              <p class="text-sm font-medium text-slate-900 dark:text-slate-100">Admin User</p>
              <p class="text-xs text-slate-600 dark:text-slate-400">admin@bmsops.com</p>
            </div>
            <%= icon "chevron-down", class: "size-4 text-slate-600 dark:text-slate-400" %>
          </button>

          <!-- User Dropdown -->
          <div 
            class="hidden absolute right-0 mt-2 w-56 bg-white dark:bg-slate-800 rounded-lg shadow-xl border border-slate-200 dark:border-slate-700 py-2 z-50"
            data-railsui-dropdown-target="menu"
            data-transition-enter-active="transition ease-out duration-200"
            data-transition-enter-from="transform opacity-0 scale-95"
            data-transition-enter-to="transform opacity-100 scale-100"
            data-transition-leave-active="transition ease-in duration-150"
            data-transition-leave-from="transform opacity-100 scale-100"
            data-transition-leave-to="transform opacity-0 scale-95"
          >
            <div class="px-4 py-3 border-b border-slate-200 dark:border-slate-700">
              <p class="text-sm font-medium text-slate-900 dark:text-slate-100">Admin User</p>
              <p class="text-sm text-slate-600 dark:text-slate-400 truncate">admin@bmsops.com</p>
            </div>
            
            <%= link_to "#", class: "flex items-center gap-3 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition" do %>
              <%= icon "user-circle", class: "size-5 stroke-current" %>
              <span>User Profile</span>
            <% end %>
            
            <%= link_to "#", class: "flex items-center gap-3 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition" do %>
              <%= icon "cog-6-tooth", class: "size-5 stroke-current" %>
              <span>Settings</span>
            <% end %>
            
            <%= link_to "#", class: "flex items-center gap-3 px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition" do %>
              <%= icon "question-mark-circle", class: "size-5 stroke-current" %>
              <span>Help & Support</span>
            <% end %>
            
            <div class="border-t border-slate-200 dark:border-slate-700 my-2"></div>
            
            <%= button_to "#", method: :delete, class: "flex items-center gap-3 px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-slate-100 dark:hover:bg-slate-700 transition w-full" do %>
              <%= icon "arrow-right-on-rectangle", class: "size-5 stroke-current" %>
              <span>Log Out</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</header>
