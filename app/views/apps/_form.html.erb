<%= form_with(model: app, class: "space-y-6") do |form| %>
  <% if app.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <%= icon "exclamation-circle", class: "size-5 text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5" %>
        <div class="flex-1">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-400 mb-2">
            <%= pluralize(app.errors.count, "error") %> prohibited this app from being saved:
          </h3>
          <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
            <% app.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Application Information</h2>
      <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Basic details about your application</p>
    </div>
    <div class="px-6 py-6 space-y-6">
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.text_field :name, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "BMS Core API" %>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Descriptive name for your application</p>
      </div>

      <div>
        <%= form.label :repository, "Repository URL", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.text_field :repository, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500 font-mono", placeholder: "https://github.com/owner/repository" %>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Full URL to your GitHub, GitLab, or Bitbucket repository</p>
        
        <div class="mt-3 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3">
          <div class="flex gap-2">
            <%= icon "information-circle", class: "size-5 text-blue-600 dark:text-blue-400 flex-shrink-0 mt-0.5" %>
            <div class="text-sm text-blue-800 dark:text-blue-300">
              <p class="font-medium mb-1">Supported formats:</p>
              <ul class="list-disc list-inside space-y-0.5 text-blue-700 dark:text-blue-400">
                <li><code class="bg-blue-100 dark:bg-blue-900/40 px-1 rounded">https://github.com/owner/repo</code></li>
                <li><code class="bg-blue-100 dark:bg-blue-900/40 px-1 rounded">https://gitlab.com/owner/repo</code></li>
                <li><code class="bg-blue-100 dark:bg-blue-900/40 px-1 rounded">https://bitbucket.org/owner/repo</code></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <%= link_to "Cancel", app.persisted? ? app : apps_path, class: "btn btn-white" %>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
