<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-4">
          <%= link_to apps_path, class: "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100" do %>
            <%= icon "arrow-left", class: "size-6" %>
          <% end %>
          <div>
            <div class="flex items-center gap-3 mb-1">
              <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100"><%= @app.name %></h1>
              <% if @app.repository_platform %>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 text-sm font-medium rounded-full bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300">
                  <%= @app.repository_platform %>
                </span>
              <% end %>
            </div>
            <p class="text-slate-600 dark:text-slate-400">Application details and repository information</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to edit_app_path(@app), class: "btn btn-white flex items-center gap-2" do %>
            <%= icon "pencil", class: "size-5" %>
            <span>Edit</span>
          <% end %>
          <%= button_to @app, method: :delete, data: { turbo_confirm: "Are you sure you want to delete #{@app.name}?" }, class: "btn btn-white text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 flex items-center gap-2" do %>
            <%= icon "trash", class: "size-5" %>
            <span>Delete</span>
          <% end %>
        </div>
      </div>

      <%= render "shared/flash_messages" %>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Info -->
        <div class="lg:col-span-2 space-y-6">
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Application Information</h2>
            </div>
            <div class="px-6 py-4">
              <dl class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Application Name</dt>
                  <dd class="text-sm text-slate-900 dark:text-slate-100"><%= @app.name %></dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Platform</dt>
                  <dd class="text-sm text-slate-900 dark:text-slate-100"><%= @app.repository_platform || "Unknown" %></dd>
                </div>
                <% if @app.repository_owner %>
                  <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Owner/Organization</dt>
                    <dd class="text-sm text-slate-900 dark:text-slate-100"><%= @app.repository_owner %></dd>
                  </div>
                <% end %>
                <% if @app.repository_short_name %>
                  <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Repository Name</dt>
                    <dd class="text-sm text-slate-900 dark:text-slate-100"><%= @app.repository_short_name %></dd>
                  </div>
                <% end %>
              </dl>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Repository</h2>
            </div>
            <div class="px-6 py-4">
              <div class="space-y-4">
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">Repository URL</dt>
                  <dd>
                    <div class="flex items-center gap-2 bg-slate-50 dark:bg-slate-900 px-4 py-3 rounded-lg">
                      <span class="text-sm text-slate-900 dark:text-slate-100 font-mono flex-1 truncate">
                        <%= @app.repository %>
                      </span>
                      <%= link_to @app.repository_url, target: "_blank", class: "text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 flex-shrink-0" do %>
                        <%= icon "arrow-top-right-on-square", class: "size-5" %>
                      <% end %>
                    </div>
                  </dd>
                </div>

                <% if @app.repository_name %>
                  <div>
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-2">Full Repository Path</dt>
                    <dd class="text-sm text-slate-900 dark:text-slate-100 font-mono bg-slate-50 dark:bg-slate-900 px-4 py-3 rounded-lg">
                      <%= @app.repository_name %>
                    </dd>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Metadata</h2>
            </div>
            <div class="px-6 py-4 space-y-4">
              <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Created</dt>
                <dd class="text-sm text-slate-900 dark:text-slate-100">
                  <%= time_tag @app.created_at, @app.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                </dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Last Updated</dt>
                <dd class="text-sm text-slate-900 dark:text-slate-100">
                  <%= time_tag @app.updated_at, @app.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
                </dd>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Quick Actions</h2>
            </div>
            <div class="px-6 py-4 space-y-2">
              <%= link_to instances_path(app_id: @app.id), class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "server", class: "size-5 text-slate-500" %>
                <div class="flex-1 flex items-center justify-between">
                  <span class="text-sm font-medium">View Instances</span>
                  <span class="px-2 py-0.5 text-xs font-semibold rounded-full bg-primary-100 dark:bg-primary-900/30 text-primary-800 dark:text-primary-400">
                    <%= @app.instances.count %>
                  </span>
                </div>
              <% end %>
              <%= link_to @app.repository_url, target: "_blank", class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "arrow-top-right-on-square", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">Open Repository</span>
              <% end %>
              <%= link_to "#", class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "document-duplicate", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">Clone Repository</span>
              <% end %>
              <%= link_to "#", class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "tag", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">View Releases</span>
              <% end %>
              <%= link_to "#", class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "cog-6-tooth", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">Deploy Service</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
