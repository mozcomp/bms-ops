<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-2">Databases</h1>
          <p class="text-slate-600 dark:text-slate-400">Manage database schemas and connections</p>
        </div>
        <%= link_to new_database_path, class: "btn btn-primary flex items-center gap-2" do %>
          <%= icon "plus", class: "size-5" %>
          <span>New Database</span>
        <% end %>
      </div>

      <%= render "shared/flash_messages" %>

      <!-- Databases Grid -->
      <% if @databases.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @databases.each do |database| %>
            <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-lg transition">
              <div class="p-6">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center gap-3 min-w-0 flex-1">
                    <div class="size-12 bg-purple-100 dark:bg-purple-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
                      <%= icon "circle-stack", class: "size-6 text-purple-600 dark:text-purple-400" %>
                    </div>
                    <div class="min-w-0 flex-1">
                      <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 truncate">
                        <%= database.name %>
                      </h3>
                      <span class="inline-flex items-center gap-1.5 px-2 py-0.5 text-xs font-medium rounded-full <%= database.status_color == 'green' ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300' : 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300' %>">
                        <span class="size-1.5 <%= database.status_color == 'green' ? 'bg-green-600 dark:bg-green-400' : 'bg-yellow-600 dark:bg-yellow-400' %> rounded-full"></span>
                        <%= database.status %>
                      </span>
                    </div>
                  </div>
                </div>

                <div class="space-y-3 mb-4">
                  <div>
                    <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Schema Version</dt>
                    <dd>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-primary-100 dark:bg-primary-900/30 text-primary-800 dark:text-primary-400">
                        <%= database.schema_version %>
                      </span>
                    </dd>
                  </div>

                  <% if database.adapter %>
                    <div>
                      <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Adapter</dt>
                      <dd class="text-sm text-slate-900 dark:text-slate-100"><%= database.adapter.titleize %></dd>
                    </div>
                  <% end %>

                  <% if database.host && database.connection.present? %>
                    <div>
                      <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Host</dt>
                      <dd class="text-sm text-slate-600 dark:text-slate-400 font-mono truncate">
                        <%= database.host %>:<%= database.port %>
                      </dd>
                    </div>
                  <% end %>

                  <div>
                    <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Created</dt>
                    <dd class="text-sm text-slate-600 dark:text-slate-400">
                      <%= time_tag database.created_at, database.created_at.strftime("%b %d, %Y") %>
                    </dd>
                  </div>
                </div>

                <div class="flex items-center gap-2 pt-4 border-t border-slate-200 dark:border-slate-700">
                  <%= link_to database, class: "flex-1 btn btn-white text-sm flex items-center justify-center gap-2" do %>
                    <%= icon "eye", class: "size-4" %>
                    <span>View</span>
                  <% end %>
                  <%= link_to edit_database_path(database), class: "flex-1 btn btn-white text-sm flex items-center justify-center gap-2" do %>
                    <%= icon "pencil", class: "size-4" %>
                    <span>Edit</span>
                  <% end %>
                  <%= button_to database, method: :delete, data: { turbo_confirm: "Are you sure you want to delete #{database.name}?" }, class: "btn btn-white text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 text-sm flex items-center justify-center gap-2" do %>
                    <%= icon "trash", class: "size-4" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
          <div class="text-center py-12">
            <div class="inline-flex items-center justify-center size-16 bg-slate-100 dark:bg-slate-700 rounded-full mb-4">
              <%= icon "circle-stack", class: "size-8 text-slate-400" %>
            </div>
            <h3 class="text-lg font-medium text-slate-900 dark:text-slate-100 mb-2">No databases yet</h3>
            <p class="text-slate-600 dark:text-slate-400 mb-6">Get started by creating your first database.</p>
            <%= link_to new_database_path, class: "btn btn-primary inline-flex items-center gap-2" do %>
              <%= icon "plus", class: "size-5" %>
              <span>New Database</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </main>
  </div>
</div>
