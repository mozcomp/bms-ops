<%= form_with(model: database, class: "space-y-6") do |form| %>
  <% if database.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <%= icon "exclamation-circle", class: "size-5 text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5" %>
        <div class="flex-1">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-400 mb-2">
            <%= pluralize(database.errors.count, "error") %> prohibited this database from being saved:
          </h3>
          <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
            <% database.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Basic Information</h2>
      <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Essential database details</p>
    </div>
    <div class="px-6 py-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="md:col-span-2">
        <%= form.label :name, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.text_field :name, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "bms_production" %>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Unique database identifier</p>
      </div>

      <div class="md:col-span-2">
        <%= form.label :schema_version, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.text_field :schema_version, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "20251126000000" %>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Current schema migration version</p>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Connection Configuration (JSON)</h2>
      <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Database connection parameters as JSON</p>
    </div>
    <div class="px-6 py-6">
      <div>
        <%= form.label :connection_json, "Connection Details", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.text_area :connection_json, rows: 12, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500 font-mono text-sm", placeholder: '{
  "adapter": "postgresql",
  "host": "localhost",
  "port": 5432,
  "database": "bms_production",
  "username": "bms_user",
  "password": "secure_password",
  "pool": 5,
  "timeout": 5000
}' %>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Connection configuration as valid JSON</p>
        
        <div class="mt-3 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3">
          <div class="flex gap-2">
            <%= icon "information-circle", class: "size-5 text-blue-600 dark:text-blue-400 flex-shrink-0 mt-0.5" %>
            <div class="text-sm text-blue-800 dark:text-blue-300">
              <p class="font-medium mb-1">Common connection parameters:</p>
              <ul class="list-disc list-inside space-y-0.5 text-blue-700 dark:text-blue-400 text-xs">
                <li><code class="bg-blue-100 dark:bg-blue-900/40 px-1 rounded">adapter</code> - Database type (postgresql, mysql2, sqlite3)</li>
                <li><code class="bg-blue-100 dark:bg-blue-900/40 px-1 rounded">host</code> - Database server hostname</li>
                <li><code class="bg-blue-100 dark:bg-blue-900/40 px-1 rounded">port</code> - Connection port</li>
                <li><code class="bg-blue-100 dark:bg-blue-900/40 px-1 rounded">database</code> - Database name</li>
                <li><code class="bg-blue-100 dark:bg-blue-900/40 px-1 rounded">username</code> - Database user</li>
                <li><code class="bg-blue-100 dark:bg-blue-900/40 px-1 rounded">password</code> - Authentication password</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <%= link_to "Cancel", database.persisted? ? database : databases_path, class: "btn btn-white" %>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
