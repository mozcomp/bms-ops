<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-4">
          <%= link_to databases_path, class: "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100" do %>
            <%= icon "arrow-left", class: "size-6" %>
          <% end %>
          <div>
            <div class="flex items-center gap-3 mb-1">
              <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100"><%= @database.name %></h1>
              <span class="inline-flex items-center gap-1.5 px-3 py-1 text-sm font-medium rounded-full <%= @database.status_color == 'green' ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300' : 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-300' %>">
                <span class="size-2 <%= @database.status_color == 'green' ? 'bg-green-600 dark:bg-green-400' : 'bg-yellow-600 dark:bg-yellow-400' %> rounded-full"></span>
                <%= @database.status %>
              </span>
            </div>
            <p class="text-slate-600 dark:text-slate-400">Database schema and connection details</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to edit_database_path(@database), class: "btn btn-white flex items-center gap-2" do %>
            <%= icon "pencil", class: "size-5" %>
            <span>Edit</span>
          <% end %>
          <%= button_to @database, method: :delete, data: { turbo_confirm: "Are you sure you want to delete #{@database.name}?" }, class: "btn btn-white text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 flex items-center gap-2" do %>
            <%= icon "trash", class: "size-5" %>
            <span>Delete</span>
          <% end %>
        </div>
      </div>

      <%= render "shared/flash_messages" %>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Info -->
        <div class="lg:col-span-2 space-y-6">
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Database Information</h2>
            </div>
            <div class="px-6 py-6 space-y-6">
              <div class="flex items-start gap-6">
                <div class="w-48 flex-shrink-0">
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Database Name</dt>
                </div>
                <div class="flex-1 min-w-0">
                  <dd class="text-sm text-slate-900 dark:text-slate-100"><%= @database.name %></dd>
                </div>
              </div>

              <div class="flex items-start gap-6">
                <div class="w-48 flex-shrink-0">
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Schema Version</dt>
                </div>
                <div class="flex-1 min-w-0">
                  <dd>
                    <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-primary-100 dark:bg-primary-900/30 text-primary-800 dark:text-primary-400">
                      <%= @database.schema_version %>
                    </span>
                  </dd>
                </div>
              </div>

              <div class="flex items-start gap-6">
                <div class="w-48 flex-shrink-0">
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Status</dt>
                </div>
                <div class="flex-1 min-w-0">
                  <dd class="text-sm text-slate-900 dark:text-slate-100"><%= @database.status %></dd>
                </div>
              </div>
            </div>
          </div>

          <!-- Connection Details -->
          <% if @database.connection.present? && @database.connection.any? %>
            <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
              <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
                <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Connection Details</h2>
              </div>
              <div class="px-6 py-6 space-y-6">
                <div class="flex items-start gap-6">
                  <div class="w-48 flex-shrink-0">
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Adapter</dt>
                  </div>
                  <div class="flex-1 min-w-0">
                    <dd class="text-sm text-slate-900 dark:text-slate-100"><%= @database.adapter.titleize %></dd>
                  </div>
                </div>

                <div class="flex items-start gap-6">
                  <div class="w-48 flex-shrink-0">
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Host</dt>
                  </div>
                  <div class="flex-1 min-w-0">
                    <dd class="text-sm text-slate-900 dark:text-slate-100 font-mono"><%= @database.host %></dd>
                  </div>
                </div>

                <div class="flex items-start gap-6">
                  <div class="w-48 flex-shrink-0">
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Port</dt>
                  </div>
                  <div class="flex-1 min-w-0">
                    <dd class="text-sm text-slate-900 dark:text-slate-100 font-mono"><%= @database.port %></dd>
                  </div>
                </div>

                <div class="flex items-start gap-6">
                  <div class="w-48 flex-shrink-0">
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Database</dt>
                  </div>
                  <div class="flex-1 min-w-0">
                    <dd class="text-sm text-slate-900 dark:text-slate-100 font-mono"><%= @database.database_name %></dd>
                  </div>
                </div>

                <% if @database.username %>
                  <div class="flex items-start gap-6">
                    <div class="w-48 flex-shrink-0">
                      <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Username</dt>
                    </div>
                    <div class="flex-1 min-w-0">
                      <dd class="text-sm text-slate-900 dark:text-slate-100 font-mono"><%= @database.username %></dd>
                    </div>
                  </div>
                <% end %>

                <div class="flex items-start gap-6">
                  <div class="w-48 flex-shrink-0">
                    <dt class="text-sm font-medium text-slate-500 dark:text-slate-400">Connection String</dt>
                  </div>
                  <div class="flex-1 min-w-0">
                    <dd class="text-sm text-slate-900 dark:text-slate-100 font-mono bg-slate-50 dark:bg-slate-900 px-4 py-3 rounded-lg break-all">
                      <%= @database.connection_string %>
                    </dd>
                  </div>
                </div>
              </div>
            </div>

            <!-- Raw Connection JSON -->
            <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
              <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
                <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Connection Configuration</h2>
              </div>
              <div class="px-6 py-4">
                <div class="bg-slate-50 dark:bg-slate-900 rounded-lg p-4 font-mono text-sm overflow-x-auto">
                  <pre class="text-slate-900 dark:text-slate-100"><%= JSON.pretty_generate(@database.connection) %></pre>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Metadata</h2>
            </div>
            <div class="px-6 py-4 space-y-4">
              <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Created</dt>
                <dd class="text-sm text-slate-900 dark:text-slate-100">
                  <%= time_tag @database.created_at, @database.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                </dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Last Updated</dt>
                <dd class="text-sm text-slate-900 dark:text-slate-100">
                  <%= time_tag @database.updated_at, @database.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
                </dd>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Quick Actions</h2>
            </div>
            <div class="px-6 py-4 space-y-2">
              <%= link_to "#", class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "arrow-path", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">Run Migrations</span>
              <% end %>
              <%= link_to "#", class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "clipboard-document-check", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">Test Connection</span>
              <% end %>
              <%= link_to "#", class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "document-duplicate", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">Create Backup</span>
              <% end %>
              <%= link_to "#", class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "chart-bar", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">View Statistics</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
