<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <!-- Breadcrumbs -->
      <nav class="flex mb-4" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <% @breadcrumbs.each_with_index do |breadcrumb, index| %>
            <li class="inline-flex items-center">
              <% if index > 0 %>
                <%= icon "chevron-right", class: "size-4 text-slate-400 mx-2" %>
              <% end %>
              <% if breadcrumb[:path] %>
                <%= link_to breadcrumb[:name], breadcrumb[:path], class: "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 text-sm font-medium" %>
              <% else %>
                <span class="text-slate-900 dark:text-slate-100 text-sm font-medium"><%= breadcrumb[:name] %></span>
              <% end %>
            </li>
          <% end %>
        </ol>
      </nav>

      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-4">
          <%= link_to admin_path, class: "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100" do %>
            <%= icon "arrow-left", class: "size-6" %>
          <% end %>
          <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-1">Document Management</h1>
            <p class="text-slate-600 dark:text-slate-400">Control document visibility and access permissions</p>
          </div>
        </div>
      </div>

      <%= render "shared/flash_messages" %>

      <!-- Filters -->
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700 mb-6">
        <div class="px-6 py-4">
          <div class="flex items-center gap-4">
            <span class="text-sm font-medium text-slate-700 dark:text-slate-300">Filter by visibility:</span>
            <%= link_to admin_documents_path, 
                class: "px-3 py-1 text-sm font-medium rounded-lg #{params[:visibility].blank? ? 'bg-primary-100 dark:bg-primary-900/30 text-primary-800 dark:text-primary-400' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700'}" do %>
              All
            <% end %>
            <%= link_to admin_documents_path(visibility: 'public'), 
                class: "px-3 py-1 text-sm font-medium rounded-lg #{params[:visibility] == 'public' ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700'}" do %>
              Public
            <% end %>
            <%= link_to admin_documents_path(visibility: 'private'), 
                class: "px-3 py-1 text-sm font-medium rounded-lg #{params[:visibility] == 'private' ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-400' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700'}" do %>
              Private
            <% end %>
            <%= link_to admin_documents_path(visibility: 'admin_only'), 
                class: "px-3 py-1 text-sm font-medium rounded-lg #{params[:visibility] == 'admin_only' ? 'bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-400' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-700'}" do %>
              Admin Only
            <% end %>
          </div>
        </div>
      </div>

      <!-- Documents Table -->
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">All Documents</h2>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">
            <%= pluralize(@documents.count, 'document') %> total
          </p>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
            <thead class="bg-slate-50 dark:bg-slate-900">
              <tr>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                  Document
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                  Visibility
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                  Status
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                  Author
                </th>
                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                  Updated
                </th>
                <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                  Actions
                </th>
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-slate-800 divide-y divide-slate-200 dark:divide-slate-700">
              <% @documents.each do |document| %>
                <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition">
                  <td class="px-6 py-4">
                    <div class="flex items-center">
                      <div class="flex-shrink-0">
                        <%= icon "document-text", class: "size-5 text-slate-400" %>
                      </div>
                      <div class="ml-3">
                        <div class="text-sm font-medium text-slate-900 dark:text-slate-100">
                          <%= link_to document.title, document_path(document), class: "hover:text-primary-600 dark:hover:text-primary-400" %>
                        </div>
                        <% if document.folder %>
                          <div class="text-sm text-slate-500 dark:text-slate-400">
                            <%= document.folder.name %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% case document.visibility %>
                    <% when 'public' %>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400">
                        <%= icon "globe-alt", class: "size-3 mr-1" %>
                        Public
                      </span>
                    <% when 'private' %>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-400">
                        <%= icon "lock-closed", class: "size-3 mr-1" %>
                        Private
                      </span>
                    <% when 'admin_only' %>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-400">
                        <%= icon "shield-check", class: "size-3 mr-1" %>
                        Admin Only
                      </span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <% if document.published? %>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400">
                        Published
                      </span>
                    <% else %>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-slate-100 dark:bg-slate-700 text-slate-800 dark:text-slate-300">
                        Draft
                      </span>
                    <% end %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-900 dark:text-slate-100">
                    <%= document.created_by.full_name %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 dark:text-slate-400">
                    <%= time_tag document.updated_at, document.updated_at.strftime("%b %d, %Y") %>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                    <div class="flex items-center justify-end gap-2">
                      <!-- Visibility Change Dropdown -->
                      <div class="relative inline-block text-left">
                        <button type="button" class="inline-flex items-center gap-1 px-3 py-1 text-sm font-medium text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 border border-slate-300 dark:border-slate-600 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700" onclick="toggleDropdown(event, 'dropdown-<%= document.id %>')">
                          Change Visibility
                          <%= icon "chevron-down", class: "size-4" %>
                        </button>
                        <div id="dropdown-<%= document.id %>" class="hidden absolute right-0 z-10 mt-2 w-48 origin-top-right rounded-md bg-white dark:bg-slate-800 shadow-lg ring-1 ring-black ring-opacity-5 focus:outline-none">
                          <div class="py-1">
                            <% unless document.visibility == 'public' %>
                              <%= button_to admin_update_document_visibility_path(document), 
                                  method: :patch, 
                                  params: { visibility: 'public' },
                                  class: "flex items-center gap-2 w-full px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700" do %>
                                <%= icon "globe-alt", class: "size-4 text-blue-600 dark:text-blue-400" %>
                                Make Public
                              <% end %>
                            <% end %>
                            <% unless document.visibility == 'private' %>
                              <%= button_to admin_update_document_visibility_path(document), 
                                  method: :patch, 
                                  params: { visibility: 'private' },
                                  class: "flex items-center gap-2 w-full px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700" do %>
                                <%= icon "lock-closed", class: "size-4 text-yellow-600 dark:text-yellow-400" %>
                                Make Private
                              <% end %>
                            <% end %>
                            <% unless document.visibility == 'admin_only' %>
                              <%= button_to admin_update_document_visibility_path(document), 
                                  method: :patch, 
                                  params: { visibility: 'admin_only' },
                                  data: { turbo_confirm: "Are you sure you want to make '#{document.title}' visible only to administrators?" },
                                  class: "flex items-center gap-2 w-full px-4 py-2 text-sm text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700" do %>
                                <%= icon "shield-check", class: "size-4 text-red-600 dark:text-red-400" %>
                                Make Admin Only
                              <% end %>
                            <% end %>
                          </div>
                        </div>
                      </div>
                      
                      <%= link_to document_path(document), class: "text-primary-600 dark:text-primary-400 hover:text-primary-900 dark:hover:text-primary-300" do %>
                        <%= icon "eye", class: "size-4" %>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </main>
  </div>
</div>

<script>
function toggleDropdown(event, dropdownId) {
  event.stopPropagation();
  const dropdown = document.getElementById(dropdownId);
  
  // Close all other dropdowns
  document.querySelectorAll('[id^="dropdown-"]').forEach(d => {
    if (d.id !== dropdownId) {
      d.classList.add('hidden');
    }
  });
  
  dropdown.classList.toggle('hidden');
}

// Close dropdowns when clicking outside
document.addEventListener('click', function() {
  document.querySelectorAll('[id^="dropdown-"]').forEach(d => {
    d.classList.add('hidden');
  });
});
</script>