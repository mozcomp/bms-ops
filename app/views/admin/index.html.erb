<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <!-- Breadcrumbs -->
      <nav class="flex mb-4" aria-label="Breadcrumb">
        <ol class="inline-flex items-center space-x-1 md:space-x-3">
          <% @breadcrumbs.each_with_index do |breadcrumb, index| %>
            <li class="inline-flex items-center">
              <% if index > 0 %>
                <%= icon "chevron-right", class: "size-4 text-slate-400 mx-2" %>
              <% end %>
              <% if breadcrumb[:path] %>
                <%= link_to breadcrumb[:name], breadcrumb[:path], class: "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 text-sm font-medium" %>
              <% else %>
                <span class="text-slate-900 dark:text-slate-100 text-sm font-medium"><%= breadcrumb[:name] %></span>
              <% end %>
            </li>
          <% end %>
        </ol>
      </nav>

      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-2">Administration</h1>
          <p class="text-slate-600 dark:text-slate-400">Manage users, documents, and system permissions</p>
        </div>
      </div>

      <%= render "shared/flash_messages" %>

      <!-- Stats Overview -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <!-- Total Users -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6 border border-slate-200 dark:border-slate-700">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Total Users</p>
              <p class="text-3xl font-bold text-slate-900 dark:text-slate-100 mt-2"><%= @users_count %></p>
            </div>
            <div class="bg-blue-100 dark:bg-blue-900/30 rounded-full p-3">
              <%= icon "users", class: "size-6 text-blue-600 dark:text-blue-400" %>
            </div>
          </div>
        </div>

        <!-- Admin Users -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6 border border-slate-200 dark:border-slate-700">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Administrators</p>
              <p class="text-3xl font-bold text-slate-900 dark:text-slate-100 mt-2"><%= @admin_users_count %></p>
            </div>
            <div class="bg-red-100 dark:bg-red-900/30 rounded-full p-3">
              <%= icon "shield-check", class: "size-6 text-red-600 dark:text-red-400" %>
            </div>
          </div>
        </div>

        <!-- Total Documents -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6 border border-slate-200 dark:border-slate-700">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Total Documents</p>
              <p class="text-3xl font-bold text-slate-900 dark:text-slate-100 mt-2"><%= @documents_count %></p>
            </div>
            <div class="bg-green-100 dark:bg-green-900/30 rounded-full p-3">
              <%= icon "document-text", class: "size-6 text-green-600 dark:text-green-400" %>
            </div>
          </div>
        </div>

        <!-- Published Documents -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow p-6 border border-slate-200 dark:border-slate-700">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Published</p>
              <p class="text-3xl font-bold text-slate-900 dark:text-slate-100 mt-2"><%= Document.published.count %></p>
            </div>
            <div class="bg-primary-100 dark:bg-primary-900/30 rounded-full p-3">
              <%= icon "eye", class: "size-6 text-primary-600 dark:text-primary-400" %>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <!-- User Management -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
          <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">User Management</h2>
            <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Manage user accounts and permissions</p>
          </div>
          <div class="px-6 py-4">
            <%= link_to admin_users_path, class: "flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-700 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-600 transition" do %>
              <div class="flex items-center gap-3">
                <%= icon "users", class: "size-6 text-blue-600 dark:text-blue-400" %>
                <div>
                  <h3 class="text-sm font-medium text-slate-900 dark:text-slate-100">Manage Users</h3>
                  <p class="text-xs text-slate-600 dark:text-slate-400">Grant or revoke admin privileges</p>
                </div>
              </div>
              <%= icon "arrow-right", class: "size-5 text-slate-400" %>
            <% end %>
          </div>
        </div>

        <!-- Document Management -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
          <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Document Management</h2>
            <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Control document visibility and access</p>
          </div>
          <div class="px-6 py-4">
            <%= link_to admin_documents_path, class: "flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-700 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-600 transition" do %>
              <div class="flex items-center gap-3">
                <%= icon "document-text", class: "size-6 text-green-600 dark:text-green-400" %>
                <div>
                  <h3 class="text-sm font-medium text-slate-900 dark:text-slate-100">Manage Documents</h3>
                  <p class="text-xs text-slate-600 dark:text-slate-400">Set visibility and permissions</p>
                </div>
              </div>
              <%= icon "arrow-right", class: "size-5 text-slate-400" %>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Recent Documents -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
          <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Recent Documents</h2>
          </div>
          <div class="divide-y divide-slate-200 dark:divide-slate-700">
            <% @recent_documents.each do |document| %>
              <div class="px-6 py-4">
                <div class="flex items-center justify-between">
                  <div class="flex-1 min-w-0">
                    <h3 class="text-sm font-medium text-slate-900 dark:text-slate-100 truncate">
                      <%= link_to document.title, document_path(document), class: "hover:text-primary-600 dark:hover:text-primary-400" %>
                    </h3>
                    <div class="flex items-center gap-2 mt-1">
                      <span class="text-xs text-slate-500 dark:text-slate-400">
                        Updated <%= time_ago_in_words(document.updated_at) %> ago
                      </span>
                      <% case document.visibility %>
                      <% when 'public' %>
                        <span class="px-1.5 py-0.5 text-xs font-medium bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400 rounded">Public</span>
                      <% when 'private' %>
                        <span class="px-1.5 py-0.5 text-xs font-medium bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-400 rounded">Private</span>
                      <% when 'admin_only' %>
                        <span class="px-1.5 py-0.5 text-xs font-medium bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-400 rounded">Admin Only</span>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Recent Users -->
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
          <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Recent Users</h2>
          </div>
          <div class="divide-y divide-slate-200 dark:divide-slate-700">
            <% @recent_users.each do |user| %>
              <div class="px-6 py-4">
                <div class="flex items-center justify-between">
                  <div>
                    <h3 class="text-sm font-medium text-slate-900 dark:text-slate-100">
                      <%= user.full_name %>
                    </h3>
                    <div class="flex items-center gap-2 mt-1">
                      <span class="text-xs text-slate-500 dark:text-slate-400">
                        Joined <%= time_ago_in_words(user.created_at) %> ago
                      </span>
                      <% if user.admin? %>
                        <span class="px-1.5 py-0.5 text-xs font-medium bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-400 rounded">Admin</span>
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>