<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <div class="mb-8">
        <h2 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-2">Welcome to BMS Ops</h2>
        <p class="text-slate-600 dark:text-slate-400">Manage your AWS infrastructure, services, and tenants</p>
      </div>

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6 mb-8">
        <%= link_to tenants_path, class: "bg-white dark:bg-slate-800 rounded-lg shadow p-6 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition" do %>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Tenants</p>
              <p class="text-3xl font-bold text-slate-900 dark:text-slate-100 mt-2"><%= Tenant.count %></p>
            </div>
            <div class="bg-primary-100 dark:bg-primary-900/30 rounded-full p-3">
              <%= icon "users", class: "size-6 text-primary-600 dark:text-primary-400" %>
            </div>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-4">Active clients</p>
        <% end %>

        <%= link_to services_path, class: "bg-white dark:bg-slate-800 rounded-lg shadow p-6 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition" do %>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Services</p>
              <p class="text-3xl font-bold text-slate-900 dark:text-slate-100 mt-2"><%= Service.count %></p>
            </div>
            <div class="bg-green-100 dark:bg-green-900/30 rounded-full p-3">
              <%= icon "server", class: "size-6 text-green-600 dark:text-green-400" %>
            </div>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-4">ECS services</p>
        <% end %>

        <%= link_to apps_path, class: "bg-white dark:bg-slate-800 rounded-lg shadow p-6 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition" do %>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Applications</p>
              <p class="text-3xl font-bold text-slate-900 dark:text-slate-100 mt-2"><%= App.count %></p>
            </div>
            <div class="bg-blue-100 dark:bg-blue-900/30 rounded-full p-3">
              <%= icon "code-bracket", class: "size-6 text-blue-600 dark:text-blue-400" %>
            </div>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-4">Repositories</p>
        <% end %>

        <%= link_to databases_path, class: "bg-white dark:bg-slate-800 rounded-lg shadow p-6 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition" do %>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Databases</p>
              <p class="text-3xl font-bold text-slate-900 dark:text-slate-100 mt-2"><%= Database.count %></p>
            </div>
            <div class="bg-purple-100 dark:bg-purple-900/30 rounded-full p-3">
              <%= icon "circle-stack", class: "size-6 text-purple-600 dark:text-purple-400" %>
            </div>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-4">Configurations</p>
        <% end %>

        <%= link_to instances_path, class: "bg-white dark:bg-slate-800 rounded-lg shadow p-6 border border-slate-200 dark:border-slate-700 hover:shadow-lg transition" do %>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-slate-600 dark:text-slate-400">Instances</p>
              <p class="text-3xl font-bold text-slate-900 dark:text-slate-100 mt-2"><%= Instance.count %></p>
            </div>
            <div class="bg-orange-100 dark:bg-orange-900/30 rounded-full p-3">
              <%= icon "cube", class: "size-6 text-orange-600 dark:text-orange-400" %>
            </div>
          </div>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-4">Deployments</p>
        <% end %>
      </div>

      <!-- Recent Activity -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
          <div class="p-6 border-b border-slate-200 dark:border-slate-700 flex items-center justify-between">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Recent Instances</h3>
            <%= link_to instances_path, class: "text-sm text-primary-600 dark:text-primary-400 hover:text-primary-900 dark:hover:text-primary-300 font-medium" do %>
              View all
            <% end %>
          </div>
          <div class="p-6">
            <% recent_instances = Instance.includes(:tenant, :app, :service).order(created_at: :desc).limit(5) %>
            <% if recent_instances.any? %>
              <div class="space-y-4">
                <% recent_instances.each do |instance| %>
                  <%= link_to instance, class: "block p-3 bg-slate-50 dark:bg-slate-700/50 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-700 transition" do %>
                    <div class="flex items-center justify-between">
                      <div class="flex items-center gap-3 min-w-0 flex-1">
                        <div class="bg-orange-100 dark:bg-orange-900/30 rounded-full p-2 flex-shrink-0">
                          <%= icon "cube", class: "size-5 text-orange-600 dark:text-orange-400" %>
                        </div>
                        <div class="min-w-0 flex-1">
                          <p class="font-medium text-slate-900 dark:text-slate-100 truncate"><%= instance.tenant.name %></p>
                          <p class="text-sm text-slate-600 dark:text-slate-400 truncate"><%= instance.app.name %> · <%= instance.environment_label %></p>
                        </div>
                      </div>
                      <span class="px-2 py-1 text-xs font-semibold rounded-full flex-shrink-0 <%= instance.environment == 'production' ? 'bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400' : instance.environment == 'staging' ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-400' : 'bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400' %>">
                        <%= instance.environment %>
                      </span>
                    </div>
                  <% end %>
                <% end %>
              </div>
            <% else %>
              <div class="text-center py-8">
                <div class="inline-flex items-center justify-center size-12 bg-slate-100 dark:bg-slate-700 rounded-full mb-3">
                  <%= icon "cube", class: "size-6 text-slate-400" %>
                </div>
                <p class="text-sm text-slate-600 dark:text-slate-400">No instances yet</p>
                <%= link_to new_instance_path, class: "inline-flex items-center gap-2 text-sm text-primary-600 dark:text-primary-400 hover:text-primary-900 dark:hover:text-primary-300 font-medium mt-2" do %>
                  <%= icon "plus", class: "size-4" %>
                  <span>Create first instance</span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
          <div class="p-6 border-b border-slate-200 dark:border-slate-700">
            <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100">System Status</h3>
          </div>
          <div class="p-6">
            <div class="space-y-4">
              <% [
                { name: "AWS ECS Services", status: "operational", percentage: 100 },
                { name: "Database Connections", status: "operational", percentage: 98 },
                { name: "API Gateway", status: "operational", percentage: 100 }
              ].each do |system| %>
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <span class="text-sm font-medium text-slate-900 dark:text-slate-100"><%= system[:name] %></span>
                    <span class="text-sm text-green-600 dark:text-green-400">
                      <%= icon "check-circle", class: "size-4 inline" %> <%= system[:status].titleize %>
                    </span>
                  </div>
                  <div class="w-full bg-slate-200 dark:bg-slate-700 rounded-full h-2">
                    <div class="bg-green-600 dark:bg-green-500 h-2 rounded-full" style="width: <%= "#{system[:percentage]}%" %>"></div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
