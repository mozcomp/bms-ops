<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="flex h-screen">
      <!-- Tree Sidebar -->
      <div class="w-80 bg-white dark:bg-slate-800 border-r border-slate-200 dark:border-slate-700 overflow-y-auto">
        <div class="p-4">
          <!-- Quick Navigation -->
          <% if Current.user %>
            <div class="flex items-center gap-2 mb-4">
              <%= link_to search_documents_path, class: "btn btn-white flex items-center gap-2 text-sm" do %>
                <%= icon "magnifying-glass", class: "size-4" %>
                <span>Search</span>
              <% end %>
              <%= link_to recent_documents_path, class: "btn btn-white flex items-center gap-2 text-sm" do %>
                <%= icon "clock", class: "size-4" %>
                <span>Recent</span>
              <% end %>
              <%= link_to bookmarks_documents_path, class: "btn btn-white flex items-center gap-2 text-sm" do %>
                <%= icon "bookmark", class: "size-4" %>
                <span>Bookmarks</span>
              <% end %>
            </div>
          <% end %>

          <!-- Document Tree -->
          <%= render "shared/document_tree" %>
        </div>
      </div>

      <!-- Main Content Area -->
      <div class="flex-1 overflow-y-auto">
        <div class="p-6">
          <!-- Breadcrumbs -->
          <nav class="flex mb-4" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
              <% @breadcrumbs.each_with_index do |breadcrumb, index| %>
                <li class="inline-flex items-center">
                  <% if index > 0 %>
                    <%= icon "chevron-right", class: "size-4 text-slate-400 mx-2" %>
                  <% end %>
                  <% if breadcrumb[:path] %>
                    <%= link_to breadcrumb[:name], breadcrumb[:path], class: "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100 text-sm font-medium" %>
                  <% else %>
                    <span class="text-slate-900 dark:text-slate-100 text-sm font-medium"><%= breadcrumb[:name] %></span>
                  <% end %>
                </li>
              <% end %>
            </ol>
          </nav>

          <!-- Header -->
          <div class="flex items-center justify-between mb-6">
            <div>
              <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-2">
                <% if @folder %>
                  <%= @folder.name %>
                <% else %>
                  Documentation
                <% end %>
              </h1>
              <p class="text-slate-600 dark:text-slate-400">
                <% if @folder %>
                  <%= @folder.description || "Browse documents in this folder" %>
                <% else %>
                  Browse and manage documentation using the tree view on the left
                <% end %>
              </p>
            </div>
            <% if Current.user&.admin? %>
              <div class="flex items-center gap-2">
                <% if @folder %>
                  <%= link_to new_folder_document_path(@folder), class: "btn btn-primary flex items-center gap-2" do %>
                    <%= icon "plus", class: "size-5" %>
                    <span>New Document</span>
                  <% end %>
                <% else %>
                  <%= link_to new_document_path, class: "btn btn-primary flex items-center gap-2" do %>
                    <%= icon "plus", class: "size-5" %>
                    <span>New Document</span>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>

          <%= render "shared/flash_messages" %>

          <!-- Content Area -->
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700 p-6">
            <% if @folder %>
              <!-- Folder Content -->
              <div class="space-y-6">
                <% if @folder.documents.published.visible_to(Current.user).any? %>
                  <div>
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-4">Documents in this folder</h2>
                    <div class="space-y-2">
                      <% @folder.documents.published.visible_to(Current.user).each do |document| %>
                        <div class="flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700/50 transition">
                          <div class="size-8 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
                            <%= icon "document-text", class: "size-4 text-blue-600 dark:text-blue-400" %>
                          </div>
                          <div class="flex-1 min-w-0">
                            <h3 class="text-sm font-medium text-slate-900 dark:text-slate-100">
                              <%= link_to document.title, document_path(document), class: "hover:text-primary-600 dark:hover:text-primary-400" %>
                            </h3>
                            <% if document.excerpt.present? %>
                              <p class="text-xs text-slate-500 dark:text-slate-400 mt-1 truncate">
                                <%= document.excerpt %>
                              </p>
                            <% end %>
                          </div>
                          <div class="text-xs text-slate-500 dark:text-slate-400">
                            <%= time_tag document.updated_at, document.updated_at.strftime("%b %d") %>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <% if @folder.children.any? %>
                  <div>
                    <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100 mb-4">Subfolders</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                      <% @folder.children.each do |subfolder| %>
                        <div class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition">
                          <div class="size-8 bg-yellow-100 dark:bg-yellow-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
                            <%= icon "folder", class: "size-4 text-yellow-600 dark:text-yellow-400" %>
                          </div>
                          <div class="flex-1 min-w-0">
                            <h3 class="text-sm font-medium text-slate-900 dark:text-slate-100">
                              <%= link_to subfolder.name, folder_path(subfolder), class: "hover:text-primary-600 dark:hover:text-primary-400" %>
                            </h3>
                            <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">
                              <%= pluralize(subfolder.documents.published.count, 'document') %>
                            </p>
                          </div>
                        </div>
                      <% end %>
                    </div>
                  </div>
                <% end %>

                <% if @folder.documents.published.visible_to(Current.user).empty? && @folder.children.empty? %>
                  <div class="text-center py-12">
                    <div class="inline-flex items-center justify-center size-16 bg-slate-100 dark:bg-slate-700 rounded-full mb-4">
                      <%= icon "folder-open", class: "size-8 text-slate-400" %>
                    </div>
                    <h3 class="text-lg font-medium text-slate-900 dark:text-slate-100 mb-2">Empty folder</h3>
                    <p class="text-slate-600 dark:text-slate-400 mb-6">This folder doesn't contain any documents or subfolders yet.</p>
                    <% if Current.user&.admin? %>
                      <%= link_to new_folder_document_path(@folder), class: "btn btn-primary inline-flex items-center gap-2" do %>
                        <%= icon "plus", class: "size-5" %>
                        <span>Add Document</span>
                      <% end %>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% else %>
              <!-- Root Documentation View -->
              <div class="text-center py-12">
                <div class="inline-flex items-center justify-center size-16 bg-slate-100 dark:bg-slate-700 rounded-full mb-4">
                  <%= icon "document-text", class: "size-8 text-slate-400" %>
                </div>
                <h3 class="text-lg font-medium text-slate-900 dark:text-slate-100 mb-2">Welcome to Documentation</h3>
                <p class="text-slate-600 dark:text-slate-400 mb-6">Use the tree view on the left to browse folders and documents, or select a document to view its content.</p>
                <% if Current.user&.admin? %>
                  <div class="flex items-center justify-center gap-3">
                    <%= link_to new_document_path, class: "btn btn-primary inline-flex items-center gap-2" do %>
                      <%= icon "plus", class: "size-5" %>
                      <span>New Document</span>
                    <% end %>
                    <%= link_to new_folder_path, class: "btn btn-white inline-flex items-center gap-2" do %>
                      <%= icon "folder-plus", class: "size-5" %>
                      <span>New Folder</span>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>