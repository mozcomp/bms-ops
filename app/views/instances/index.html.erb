<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-2">Instances</h1>
          <p class="text-slate-600 dark:text-slate-400">Manage tenant deployments across environments</p>
        </div>
        <%= link_to new_instance_path, class: "btn btn-primary flex items-center gap-2" do %>
          <%= icon "plus", class: "size-5" %>
          <span>New Instance</span>
        <% end %>
      </div>

      <%= render "shared/flash_messages" %>

      <!-- Filters -->
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700 p-4 mb-6">
        <%= form_with url: instances_path, method: :get, class: "grid grid-cols-1 md:grid-cols-3 gap-4" do |f| %>
          <div>
            <%= f.label :tenant_id, "Filter by Tenant", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
            <%= f.select :tenant_id, 
                options_for_select([["All Tenants", ""]] + Tenant.order(:name).pluck(:name, :id), params[:tenant_id]), 
                {}, 
                class: "form-select w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500" %>
          </div>
          
          <div>
            <%= f.label :environment, "Filter by Environment", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
            <%= f.select :environment, 
                options_for_select([["All Environments", ""], ["Production", "production"], ["Staging", "staging"], ["Development", "development"]], params[:environment]), 
                {}, 
                class: "form-select w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500" %>
          </div>
          
          <div>
            <%= f.label :service_id, "Filter by Service", class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
            <%= f.select :service_id, 
                options_for_select([["All Services", ""]] + Service.order(:name).pluck(:name, :id), params[:service_id]), 
                {}, 
                class: "form-select w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500" %>
          </div>
          
          <div class="md:col-span-3 flex items-center gap-2">
            <%= f.submit "Apply Filters", class: "btn btn-primary" %>
            <%= link_to "Clear Filters", instances_path, class: "btn btn-white" %>
          </div>
        <% end %>
      </div>

      <!-- Instances List -->
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700 overflow-hidden">
        <% if @instances.any? %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
              <thead class="bg-slate-50 dark:bg-slate-900">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    Name
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    Tenant
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    App
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    Service
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    Environment
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    Virtual Host
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    Created
                  </th>
                  <th scope="col" class="relative px-6 py-3">
                    <span class="sr-only">Actions</span>
                  </th>
                </tr>
              </thead>
              <tbody class="bg-white dark:bg-slate-800 divide-y divide-slate-200 dark:divide-slate-700">
                <% @instances.each do |instance| %>
                  <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition">
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="text-sm font-medium text-slate-900 dark:text-slate-100">
                        <%= link_to instance.name, instance_path(instance), class: "hover:text-primary-600 dark:hover:text-primary-400" %>
                      </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <%= link_to instance.tenant, class: "text-sm font-medium text-primary-600 dark:text-primary-400 hover:underline" do %>
                        <%= instance.tenant.name %>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <%= link_to instance.app, class: "text-sm text-slate-900 dark:text-slate-100 hover:text-primary-600 dark:hover:text-primary-400" do %>
                        <%= instance.app.name %>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <%= link_to instance.service, class: "text-sm text-slate-900 dark:text-slate-100 hover:text-primary-600 dark:hover:text-primary-400" do %>
                        <%= instance.service.name %>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <% case instance.environment %>
                      <% when "production" %>
                        <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400">
                          Production
                        </span>
                      <% when "staging" %>
                        <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-400">
                          Staging
                        </span>
                      <% when "development" %>
                        <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400">
                          Development
                        </span>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                      <%= link_to instance.full_url, target: "_blank", class: "hover:text-primary-600 dark:hover:text-primary-400 flex items-center gap-1" do %>
                        <span><%= instance.virtual_host %></span>
                        <%= icon "arrow-top-right-on-square", class: "size-3" %>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                      <%= time_tag instance.created_at, instance.created_at.strftime("%b %d, %Y") %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                      <div class="flex items-center justify-end gap-2">
                        <%= link_to instance, class: "text-primary-600 dark:text-primary-400 hover:text-primary-900 dark:hover:text-primary-300" do %>
                          <%= icon "eye", class: "size-5" %>
                        <% end %>
                        <%= link_to edit_instance_path(instance), class: "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100" do %>
                          <%= icon "pencil", class: "size-5" %>
                        <% end %>
                        <%= button_to instance, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this instance?" }, class: "text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300" do %>
                          <%= icon "trash", class: "size-5" %>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center py-12">
            <div class="inline-flex items-center justify-center size-16 bg-slate-100 dark:bg-slate-700 rounded-full mb-4">
              <%= icon "server", class: "size-8 text-slate-400" %>
            </div>
            <h3 class="text-lg font-medium text-slate-900 dark:text-slate-100 mb-2">No instances yet</h3>
            <p class="text-slate-600 dark:text-slate-400 mb-6">Get started by creating your first instance.</p>
            <%= link_to new_instance_path, class: "btn btn-primary inline-flex items-center gap-2" do %>
              <%= icon "plus", class: "size-5" %>
              <span>New Instance</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </main>
  </div>
</div>
