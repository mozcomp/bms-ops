<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div class="flex items-center gap-4">
          <%= link_to instances_path, class: "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100" do %>
            <%= icon "arrow-left", class: "size-6" %>
          <% end %>
          <div>
            <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-1">
              <%= @instance.name %>
            </h1>
            <p class="text-slate-600 dark:text-slate-400">Instance deployment details</p>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to edit_instance_path(@instance), class: "btn btn-white flex items-center gap-2" do %>
            <%= icon "pencil", class: "size-5" %>
            <span>Edit</span>
          <% end %>
          <%= button_to @instance, method: :delete, data: { turbo_confirm: "Are you sure you want to delete this instance?" }, class: "btn btn-white text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 flex items-center gap-2" do %>
            <%= icon "trash", class: "size-5" %>
            <span>Delete</span>
          <% end %>
        </div>
      </div>

      <%= render "shared/flash_messages" %>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Info -->
        <div class="lg:col-span-2 space-y-6">
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Deployment Information</h2>
            </div>
            <div class="px-6 py-4">
              <dl class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Instance Name</dt>
                  <dd class="text-sm text-slate-900 dark:text-slate-100 font-medium"><%= @instance.name %></dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Tenant</dt>
                  <dd>
                    <%= link_to @instance.tenant, class: "text-sm text-primary-600 dark:text-primary-400 hover:underline" do %>
                      <%= @instance.tenant.name %>
                    <% end %>
                  </dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Tenant Code</dt>
                  <dd>
                    <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-slate-100 dark:bg-slate-700 text-slate-800 dark:text-slate-300">
                      <%= @instance.tenant.code %>
                    </span>
                  </dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Application</dt>
                  <dd>
                    <%= link_to @instance.app, class: "text-sm text-primary-600 dark:text-primary-400 hover:underline" do %>
                      <%= @instance.app.name %>
                    <% end %>
                  </dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Repository</dt>
                  <dd>
                    <%= link_to @instance.app.repository_url, target: "_blank", class: "text-sm text-slate-900 dark:text-slate-100 hover:text-primary-600 dark:hover:text-primary-400 flex items-center gap-1" do %>
                      <span class="font-mono"><%= @instance.app.repository_name %></span>
                      <%= icon "arrow-top-right-on-square", class: "size-3" %>
                    <% end %>
                  </dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Service</dt>
                  <dd>
                    <%= link_to @instance.service, class: "text-sm text-primary-600 dark:text-primary-400 hover:underline" do %>
                      <%= @instance.service.name %>
                    <% end %>
                  </dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Service Image</dt>
                  <dd class="text-sm text-slate-900 dark:text-slate-100 font-mono bg-slate-50 dark:bg-slate-900 px-3 py-2 rounded">
                    <%= @instance.service.full_image %>
                  </dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Environment</dt>
                  <dd>
                    <% case @instance.environment %>
                    <% when "production" %>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400">
                        Production
                      </span>
                    <% when "staging" %>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-400">
                        Staging
                      </span>
                    <% when "development" %>
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-800 dark:text-blue-400">
                        Development
                      </span>
                    <% end %>
                  </dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Virtual Host</dt>
                  <dd>
                    <%= link_to @instance.full_url, target: "_blank", class: "text-sm text-primary-600 dark:text-primary-400 hover:underline flex items-center gap-1" do %>
                      <span><%= @instance.virtual_host %></span>
                      <%= icon "arrow-top-right-on-square", class: "size-4" %>
                    <% end %>
                  </dd>
                </div>
              </dl>
            </div>
          </div>

          <% if @instance.env_vars.present? && @instance.env_vars.any? %>
            <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
              <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
                <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Environment Variables</h2>
              </div>
              <div class="px-6 py-4">
                <dl class="grid grid-cols-1 gap-4">
                  <% @instance.env_vars.each do |key, value| %>
                    <div class="flex items-start gap-4">
                      <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 font-mono min-w-[200px]"><%= key %></dt>
                      <dd class="text-sm text-slate-900 dark:text-slate-100 font-mono bg-slate-50 dark:bg-slate-900 px-3 py-2 rounded flex-1 break-all">
                        <%= value %>
                      </dd>
                    </div>
                  <% end %>
                </dl>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Metadata</h2>
            </div>
            <div class="px-6 py-4 space-y-4">
              <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Created</dt>
                <dd class="text-sm text-slate-900 dark:text-slate-100">
                  <%= time_tag @instance.created_at, @instance.created_at.strftime("%B %d, %Y at %I:%M %p") %>
                </dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">Last Updated</dt>
                <dd class="text-sm text-slate-900 dark:text-slate-100">
                  <%= time_tag @instance.updated_at, @instance.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
                </dd>
              </div>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
            <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
              <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Quick Actions</h2>
            </div>
            <div class="px-6 py-4 space-y-2">
              <%= link_to @instance.full_url, target: "_blank", class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "arrow-top-right-on-square", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">Open Application</span>
              <% end %>
              <%= link_to @instance.tenant, class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "users", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">View Tenant</span>
              <% end %>
              <%= link_to @instance.app, class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "code-bracket", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">View App</span>
              <% end %>
              <%= link_to @instance.service, class: "flex items-center gap-3 p-3 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 transition" do %>
                <%= icon "server", class: "size-5 text-slate-500" %>
                <span class="text-sm font-medium">View Service</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</div>
