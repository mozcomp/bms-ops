<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-2">Tenants</h1>
          <p class="text-slate-600 dark:text-slate-400">Manage client environments and configurations</p>
        </div>
        <%= link_to new_tenant_path, class: "btn btn-primary flex items-center gap-2" do %>
          <%= icon "plus", class: "size-5" %>
          <span>New Tenant</span>
        <% end %>
      </div>

      <%= render "shared/flash_messages" %>

      <!-- Tenants List -->
      <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700 overflow-hidden">
        <% if @tenants.any? %>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
              <thead class="bg-slate-50 dark:bg-slate-900">
                <tr>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    Tenant
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    Code
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    URL
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    Contact
                  </th>
                  <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-slate-500 dark:text-slate-400 uppercase tracking-wider">
                    Created
                  </th>
                  <th scope="col" class="relative px-6 py-3">
                    <span class="sr-only">Actions</span>
                  </th>
                </tr>
              </thead>
              <tbody class="bg-white dark:bg-slate-800 divide-y divide-slate-200 dark:divide-slate-700">
                <% @tenants.each do |tenant| %>
                  <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition">
                    <td class="px-6 py-4 whitespace-nowrap">
                      <div class="flex items-center">
                        <div class="flex-shrink-0 size-10 bg-primary-100 dark:bg-primary-900/30 rounded-full flex items-center justify-center">
                          <span class="text-primary-600 dark:text-primary-400 font-bold text-sm"><%= tenant.code&.first(2)&.upcase %></span>
                        </div>
                        <div class="ml-4">
                          <div class="text-sm font-medium text-slate-900 dark:text-slate-100">
                            <%= tenant.name %>
                          </div>
                        </div>
                      </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                      <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-slate-100 dark:bg-slate-700 text-slate-800 dark:text-slate-300">
                        <%= tenant.code %>
                      </span>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                      <%= link_to tenant.url, target: "_blank", class: "hover:text-primary-600 dark:hover:text-primary-400 flex items-center gap-1" do %>
                        <span><%= tenant.code %>.bmserp.com</span>
                        <%= icon "arrow-top-right-on-square", class: "size-3" %>
                      <% end %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                      <%= tenant.contact || "Not specified" %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-600 dark:text-slate-400">
                      <%= time_tag tenant.created_at, tenant.created_at.strftime("%b %d, %Y") %>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                      <div class="flex items-center justify-end gap-2">
                        <%= link_to tenant, class: "text-primary-600 dark:text-primary-400 hover:text-primary-900 dark:hover:text-primary-300" do %>
                          <%= icon "eye", class: "size-5" %>
                        <% end %>
                        <%= link_to edit_tenant_path(tenant), class: "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100" do %>
                          <%= icon "pencil", class: "size-5" %>
                        <% end %>
                        <%= button_to tenant, method: :delete, data: { turbo_confirm: "Are you sure you want to delete #{tenant.name}?" }, class: "text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300" do %>
                          <%= icon "trash", class: "size-5" %>
                        <% end %>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="text-center py-12">
            <div class="inline-flex items-center justify-center size-16 bg-slate-100 dark:bg-slate-700 rounded-full mb-4">
              <%= icon "users", class: "size-8 text-slate-400" %>
            </div>
            <h3 class="text-lg font-medium text-slate-900 dark:text-slate-100 mb-2">No tenants yet</h3>
            <p class="text-slate-600 dark:text-slate-400 mb-6">Get started by creating your first tenant.</p>
            <%= link_to new_tenant_path, class: "btn btn-primary inline-flex items-center gap-2" do %>
              <%= icon "plus", class: "size-5" %>
              <span>New Tenant</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </main>
  </div>
</div>
