<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <!-- Header -->
      <div class="flex items-center gap-4 mb-6">
        <%= link_to tenants_path, class: "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-100" do %>
          <%= icon "arrow-left", class: "size-6" %>
        <% end %>
        <div>
          <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-1">New Tenant</h1>
          <p class="text-slate-600 dark:text-slate-400">Create a new tenant environment</p>
        </div>
      </div>

      <%= render "form", tenant: @tenant %>
    </main>
  </div>
</div>
