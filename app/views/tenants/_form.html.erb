<%= form_with(model: tenant, class: "space-y-6") do |form| %>
  <% if tenant.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <%= icon "exclamation-circle", class: "size-5 text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5" %>
        <div class="flex-1">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-400 mb-2">
            <%= pluralize(tenant.errors.count, "error") %> prohibited this tenant from being saved:
          </h3>
          <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
            <% tenant.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Basic Information</h2>
      <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Essential tenant details and identifiers</p>
    </div>
    <div class="px-6 py-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :name, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.text_field :name, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "Acme Corporation" %>
      </div>

      <div>
        <%= form.label :code, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.text_field :code, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "acme" %>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Unique identifier (lowercase, no spaces)</p>
      </div>

      <div class="md:col-span-2">
        <%= form.label :contact, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.text_field :contact, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "John Smith" %>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Primary contact person for this tenant</p>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Contact Information</h2>
      <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Additional contact details and company information</p>
    </div>
    <div class="px-6 py-6 grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <%= form.label :email, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.email_field :email, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "contact@acme.com" %>
      </div>

      <div>
        <%= form.label :phone, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.telephone_field :phone, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "+1-555-0123" %>
      </div>

      <div class="md:col-span-2">
        <%= form.label :company, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.text_field :company, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "Acme Corporation" %>
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Company or organization name</p>
      </div>

      <div class="md:col-span-2">
        <%= form.label :address, class: "block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2" %>
        <%= form.text_area :address, rows: 3, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "123 Main St, City, State 12345" %>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <%= link_to "Cancel", tenant.persisted? ? tenant : tenants_path, class: "btn btn-white" %>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
