<%# locals: (icon:, title:) %>
<div class="py-8 grid grid-cols-1 md:grid-cols-10 md:gap-10 gap-3 items-start">
  <div class="col-span-3 flex items-center md:gap-6 gap-3">
    <div class="flex items-center justify-center rounded-full md:size-10 size-8 bg-primary-50 flex-shrink-0">
      <%= icon icon, class: "md:size-5 size-4 stroke-current text-primary-600" %>
    </div>
    <h4 class="h5"><%= title %></h4>
  </div>
  <div class="col-span-7">
    <div class="prose dark:prose-invert md:prose-ul:pl-0 prose-ul:pl-3">
      <%= yield %>
    </div>
  </div>
</div>
