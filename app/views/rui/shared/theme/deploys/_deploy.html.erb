<%# locals: (path: "#", status: "live", avatar_variant: "men", avatar_id: "32", account: "", branch: "", name: "", commit: "", time: "", environment: "production", server: "server-name") %>
<li>
  <%= link_to path, class: "flex flex-col md:flex-row md:items-center gap-6 py-4 hover:bg-gray-50/50 px-4 group dark:hover:bg-gray-800/50 border-0 card" do %>
    <div class="flex-1">
      <div class="flex items-center gap-4">
        <div class="flex-1 flex items-center gap-4">
          <% if status == "live" %>
            <div
            class="size-2 rounded-full bg-emerald-400 ring-4 ring-emerald-100/50 dark:ring-emerald-500/30 dark:bg-emerald-500 shrink-0">
            </div>
          <% elsif status == "pending" %>
            <div
            class="size-2 rounded-full bg-amber-300 ring-4 ring-amber-100/50 dark:bg-amber-400 dark:ring-amber-500/30 shrink-0">
            </div>
          <% else %>
            <div class="size-2 rounded-full bg-red-500 ring-4 ring-red-100/50 dark:bg-red-500 dark:ring-red-500/30 shrink-0">
            </div>
          <% end %>

          <div class="flex items-center gap-1.5">
            <div class="flex items-center -space-x-1">
              <%= icon "github", custom_path: "/railsui/brands/github.svg", class: "size-5 fill-current text-gray-700 dark:text-gray-300" %>
              <%= image_tag demo_avatar_url(variant: avatar_variant, id: avatar_id), class: "rounded-full size-5 flex-shrink-0 ring-2 ring-gray-100 dark:ring-gray-900", alt: "Avatar" %>
            </div>
            <p class="font-semibold text-gray-800 dark:text-gray-100 text-[15px]"><%= account %><span
                class="font-normal text-gray-500 dark:text-gray-600">/</span><%= branch %></p>
          </div>
        </div>

      </div>
      <div class="flex items-center justify-between pt-2 pl-[22px] relative">
        <p class="text-xs font-medium dark:text-gray-300"><%= name  %><span class="font-normal">&bull;
            <code>#<%= commit %></code> <span class="dark:text-gray-500 text-gray-500">-</span> <code><%= server %></code>
            &bull; <%= time %></span></p>
      </div>
    </div>

    <div class="flex md:justify-end">
      <% if environment == "staging" %>
        <div
        class="rounded-md px-2 py-1 text-center inline-flex justify-center bg-secondary-50/30 font-medium text-xs border border-secondary-500/10 text-secondary-700 dark:bg-secondary-500/70 dark:text-secondary-50 dark:ring-1 dark:ring-secondary-300/60">Staging</div>
      <% else %>
        <div class="rounded-md px-2 py-1 text-center inline-flex justify-center bg-emerald-50/50 text-emerald-800 font-medium text-xs border border-emerald-500/20 dark:bg-emerald-500/20 dark:text-emerald-100">Production</div>
      <% end %>
    </div>

    <div class="md:block hidden">
      <%= icon "chevron-right", class: "size-5 stroke-current text-gray-400/80 group-hover:transform group-hover:translate-x-1
      group-hover:duration-200 group-hover:text-primary-500 transition ease-in-out duration-200 dark:group-hover:text-gray-300" %>
    </div>
  <% end %>
</li>
