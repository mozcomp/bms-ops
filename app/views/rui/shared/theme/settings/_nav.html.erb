    <%= nav_link_to "Account", rui_settings_path, active_class: active_class, inactive_class: inactive_class %>
  </li>
  <li>
    <%= nav_link_to "Notifications",rui_settings_notifications_path, active_class: active_class, inactive_class: inactive_class %>
  </li>
  <li>
    <%= nav_link_to "Team", rui_settings_team_path, active_class: active_class, inactive_class: inactive_class %>
  </li>
  <li>
    <%= nav_link_to "Billing", rui_settings_billing_path, active_class: active_class, inactive_class: inactive_class %>
  </li>
  <li>
    <%= nav_link_to "Integrations", rui_settings_integrations_path, active_class: active_class, inactive_class: inactive_class %>
  </li>
</ul>
