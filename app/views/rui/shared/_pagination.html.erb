<%# locals: (align: "left") %>

<%# Note: You might opt for the pagy component in the Rails UI design patterns instead of this file. Use this file as simple a guideline for aesthetics if you roll something custom for pagination %>

<% alignment_class = case align
  when "left"
    "justify-start"
  when "center"
    "justify-center"
  when "right"
    "justify-end"
  else
    "justify-start"
  end
%>

<nav aria-label="Page navgiation" class="text-gray-600 text-sm font-medium dark:text-gray-300 my-10">
  <ul class="flex flex-wrap items-center md:gap-x-3 gap-x-1 md:justify-start <%= alignment_class %>">
    <!--
      <li>
        <%# link_to "#", class: "btn btn-transparent group" do %>
          <%#= icon "arrow-small-left", class: "size-5 text-gray-400 group-hover:text-primary-500 dark:group-hover:text-gray-200" %>
        <%# end %>
      </li>
    -->
    <li>
      <%= link_to "1", "#", class: "py-2 px-4 border-t-2 block border-primary-500 hover:bg-primary-50/50 text-primary-600 dark:text-primary-500 dark:border-primary-500 dark:hover:bg-primary-500/30" %>
    </li>
    <li>
      <%= link_to "2", "#", class: "py-2 px-4 block border-t-2 border-transparent rounded hover:bg-gray-50 dark:hover:bg-gray-500/30 dark:hover:text-gray-200" %>
    </li>
    <li>
      <%= link_to "3", "#", class: "py-2 px-4 block border-t-2 border-transparent rounded hover:bg-gray-50 dark:hover:bg-gray-500/30 dark:hover:text-gray-200" %>
    </li>
    <li>
      <span class="py-2 px-4 block border-t-2 border-transparent rounded pointer-events-none select-none">&hellip;</span>
    </li>
    <li>
      <%= link_to "7", "#", class: "py-2 px-4 block border-t-2 border-transparent rounded hover:bg-gray-50 dark:hover:bg-gray-500/30 dark:hover:text-gray-200" %>
    </li>
    <li>
      <%= link_to "8", "#", class: "py-2 px-4 block border-t-2 border-transparent rounded hover:bg-gray-50 dark:hover:bg-gray-500/30 dark:hover:text-gray-200" %>
    </li>
    <li>
      <%= link_to "#", class: "btn btn-transparent group" do %>
        <%= icon "arrow-small-right", class: "size-5 text-gray-500 group-hover:text-primary-500 dark:group-hover:text-gray-200" %>
      <% end %>
    </li>
  </ul>
</nav>
