          {variant: "women", id: "53"},
          {variant: "men", id: "61"},
          {variant: "men", id: "45"},
          {variant: "men", id: "73"}].each do |contributor| %>
          <li>
            <%= image_tag demo_avatar_url(variant: contributor[:variant], id: contributor[:id]), class: "size-7 rounded-full object-center object-cover" %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
