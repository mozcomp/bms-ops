              amount: "$1,299.99"
            },
            {
              name: "Emily Davis",
              id: "8600639",
              date: "05/22/24",
              amount: "$499.50"
            },
            {
              name: "David Wilson",
              id: "8600640",
              date: "05/23/24",
              amount: "$799.23"
            },
            {
              name: "Jennifer Miller",
              id: "8600640",
              date: "05/24/24",
              amount: "$299.99"
            },
            {
              name: "Chris Anderson",
              id: "8600642",
              date: "05/25/24",
              amount: "$382.32"
            }].each do |invoice| %>
            <tr>
              <td
                class="py-3.5 border-b border-gray-200/80 dark:border-gray-700/80 whitespace-nowrap px-1 text-sm underline underline-offset-2">
                <%= link_to invoice[:id], "#", class: "btn-link" %>
              </td>
              <td class="py-3.5 border-b border-gray-200/80 dark:border-gray-700/80 whitespace-nowrap px-1"><%= invoice[:date] %></td>
              <td class="py-3.5 border-b border-gray-200/80 dark:border-gray-700/80 whitespace-nowrap px-1"><%= invoice[:name] %></td>
              <td class="text-right py-3.5 border-b border-gray-200/80 dark:border-gray-700/80 whitespace-nowrap px-1"><%= invoice[:amount] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

