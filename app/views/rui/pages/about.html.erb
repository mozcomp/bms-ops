<% content_for :header do %>
  <header class="max-w-7xl mx-auto md:px-6 px-4 md:mb-0 mb-6 relative z-50" data-controller="railsui-toggle">
    <%= render "rui/shared/nav_menu" %>

    <div class="text-center relative">
      <div class="relative flex justify-end md:order-2 order-1 z-10 mb-10 overflow-hidden">
        <div
        class="bg-fuchsia-300/30 w-[680px] h-[580px] absolute -bottom-6 -right-16 z-30 mix-blend-multiply rounded-full blur-lg md:block hidden">
        </div>
        <div
        class="bg-primary-500/30 w-[660px] h-[460px] absolute -bottom-4 -right-14 z-30 mix-blend-multiply rounded-full blur-xl md:block hidden">
        </div>
        <%= image_tag "railsui/hero.jpg", alt: "Retriever hero image", class: "max-w-full object-cover md:h-[490px] h-[160px] w-full relative z-10 object-left" %>
      </div>
      <div
      class="md:w-[1100px] w-full h-[680px] bg-gradient-to-br from-primary-500/10 via-fuchsia-400/5 to-secondary-500/10 blur-2xl absolute left-0 top-0 opacity-20 z-0">
      </div>
      <div
      class="md:order-1 order-2 relative z-30 md:-mt-48 md:bg-white/95 dark:md:bg-gray-800/60 md:backdrop-blur-lg max-w-5xl mx-auto md:p-10">
        <div
        class="rounded-full py-2 px-3 border border-gray-300/60 bg-white inline-flex items-center space-x-3 font-medium text-sm text-gray-700 z-10 dark:bg-gray-950/50 dark:text-white dark:border-transparent">
          <%= icon "user-plus", class: "size-5 stroke-current text-secondary-300 dark:text-primary-500" %>
          <span>We’re hiring!</span>
          <%= link_to "#", class: "text-primary-500 flex items-center space-x-2 hover:text-primary-600 group" do %>
            <span>Visit careers page</span>
            <%= icon "chevron-right", class: "size-3 stroke-current relative top-[1.5px] group-hover:translate-x-[2px] group-hover:transition transition group-hover:transform group-hover:ease" %>
          <% end %>
        </div>

        <div class="mt-10">
          <h1 class="md:display-4 display-5 lg:display-4 my-3">Get to know us</h1>
          <div class="text-gray-800 text-lg leading-relaxed mb-4 opacity-80 max-w-2xl mx-auto dark:text-gray-200">
            <p>We're a dedicated team of tech enthusiasts on a mission to redefine server software, one innovative solution at a time.</p>
          </div>
          <div class="gap-5 flex items-center justify-center md:mt-6">
            <%= link_to "How we work", "#", class: "btn btn-primary" %>
            <%= link_to "Join our team", "#", class: "btn btn-white" %>
          </div>
        </div>
      </div>
    </div>
  </header>
<% end %>

<div class="max-w-7xl mx-auto pt-16 px-4">
  <div class="gap-8 md:mb-20 mb-6 flex flex-col items-center justify-center text-center md:px-0 px-4">
    <div>
      <blockquote
        class="md:text-xl text-lg font-light text-gray-700/80 leading-8 [text-indent:-14px] text-center mx-auto max-w-2xl dark:text-gray-200">&ldquo;Retriever has revolutionized so many workflows. I'm forever grateful to be part of such an amazing team. &rdquo;</blockquote>
    </div>
    <div>
      <%= image_tag "railsui/quote-author-1.png", alt: "Jack Syan", class: "size-16 inline-block" %>
      <div class="mt-3 block text-base font-semibold text-gray-900 dark:text-gray-400">
        Jack Syan
      </div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4">
  <div class="grid md:grid-cols-5 items-center justify-between">
    <div class="md:col-span-3 flex justify-center flex-col items-center h-full">
      <%= image_tag "railsui/growth.png", alt: "Our growth depends on our users’ growth", class: "w-full object-cover h-full" %>
    </div>
    <div class="md:col-span-2 bg-secondary-500 flex flex-col h-full justify-center md:p-14 p-8">
      <div class="rounded-full w-16 h-16 bg-primary-500 flex items-center justify-center mb-8">
        <%= icon "chart-bar", class: "stroke-current size-6 text-secondary-500" %>
      </div>
      <h2 class="h2 text-white">Our growth depends on our users’ growth</h2>
      <div class="prose text-white dark:prose-invert my-4 prose-lg md:pr-12">
        <p>Experience seamless scalability and unparalleled support. We're here to fuel your success, through every stage of your hosting journey.</p>
      </div>

      <%= link_to "#", class: "text-white/95 hover:text-white flex items-center gap-2 py-3 group" do %>
        <span>Read case study</span>
        <%= icon "chevron-right", class: "size-3 stroke-current relative top-px group-hover:translate-x-1 group-hover:transform
        transition ease-in-out" %>
      <% end %>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto md:py-16 py-8 px-4">
  <div class="md:py-16">
    <div class="my-8">
      <h2 class="h2 mb-4">Serving the best of the best</h2>
      <div class="prose prose-lg prose-gray dark:prose-invert">
        <p>Join the ranks of industry leaders who trust us with their hosting needs. From Fortune 500 giants to innovative startups, our platform caters to the demands of companies worldwide.</p>
      </div>
    </div>
    <div class="flex md:flex-row flex-col items-center justify-between gap-6 py-6">
      <div class="md:w-1/6 flex items-center">
        <%= image_tag "railsui/logos/amazon.svg", class: "dark:invert dark:brightness-50" %>
      </div>
      <div class="md:w-1/6 flex items-center">
        <%= image_tag "railsui/logos/mailchimp.svg", class: "dark:invert dark:brightness-50" %>
      </div>
      <div class="md:w-1/6 flex items-center">
        <%= image_tag "railsui/logos/netflix.svg", class: "dark:invert dark:brightness-50" %>
      </div>
      <div class="md:w-1/6 flex items-center">
        <%= image_tag "railsui/logos/google.svg", class: "dark:invert dark:brightness-50" %>
      </div>
      <div class="md:w-1/6 flex items-center">
        <%= image_tag "railsui/logos/uber.svg", class: "dark:invert dark:brightness-50" %>
      </div>
      <div class="md:w-1/6 flex items-center">
        <%= image_tag "railsui/logos/kroger.svg", class: "dark:invert dark:brightness-50" %>
      </div>
    </div>
  </div>
</div>

<div class="py-16 bg-gray-800 dark:bg-gray-800 text-white px-4">
  <div class="flex flex-wrap justify-center items-center md:gap-16 gap-4">
    <p class="text-lg md:text-xl text-center md:text-left">Make an impact helping us evolve our super cool technology.</p>
    <%= link_to "View open roles", "#", class: "btn btn-primary" %>
  </div>
</div>

<div class="bg-gray-50/90 md:py-40 py-16 dark:bg-gray-950">
  <div class="max-w-7xl mx-auto px-4">
    <div class="relative md:p-6 md:-left-6">
      <h2 class="md:display-5 display-6 z-10 relative">The right people don’t <br class="md:block hidden" />
        always think they’re right</h2>
      <%= image_tag "railsui/polka-dots-blue.svg", alt: "Polkadots", class: "absolute top-0 left-0 z-0 dark:opacity-30" %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 md:gap-10 prose prose-gray prose-lg dark:prose-invert w-full max-w-full">
       <div class="md:col-span-1">
        <p class="lead">We believe in fostering a culture of continuous learning and innovation. Our team members are encouraged to challenge assumptions, experiment with new ideas, and share their knowledge with others.</p>

        <p>Our commitment to diversity and inclusion isn't just a statement - it's reflected in our hiring practices, workplace policies, and day-to-day operations. We understand that different perspectives lead to better solutions.</p>
      </div>
      <div class="md:col-span-1">
        <p>We maintain a flexible work environment that prioritizes results over rigid schedules. Our teams are empowered to work in ways that best suit their needs while delivering exceptional outcomes for our clients.</p>

        <p>As a global company, we embrace the challenges and opportunities that come with working across different time zones and cultures. We've built our processes and tools to support seamless collaboration, ensuring that geography never stands in the way of great work.</p>
      </div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-4 py-16 md:py-40">
  <div class="flex justify-center mb-6">
    <div class="flex items-center justify-center size-16 rounded-full bg-secondary-600">
      <svg class="stroke-current text-primary-500 size-6" width="16" height="16" viewBox="0 0 16 16" fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path d="M0.75 2.75L5.25 0.75V13.25L0.75 15.25V2.75Z" stroke-width="1.5" stroke-linecap="round"
          stroke-linejoin="round" />
        <path d="M10.75 2.75L15.25 0.75V13.25L10.75 15.25V2.75Z" stroke-width="1.5" stroke-linecap="round"
          stroke-linejoin="round" />
        <path d="M10.75 2.75L5.25 0.75V13.25L10.75 15.25V2.75Z" stroke-width="1.5" stroke-linecap="round"
          stroke-linejoin="round" />
      </svg>
    </div>
  </div>

  <div class="flex items-center justify-center mb-16">
    <div class="text-center">
      <h2 class="h2 mb-6">Headquartered across the globe</h2>
      <div class="prose prose-lg prose-gray text-center dark:prose-invert">

        <p>We don't discriminate on geography. If you're passionate, do good work, and show up, you'll fit right in. If that's you, join us.</p>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-3 md:gap-6 gap-4">
    <div>
      <div class="relative">
        <%= image_tag "railsui/tokyo.jpg", alt: "Tokyo", class: "max-w-full" %>
        <h3 class="md:h3 h4 text-white/95 absolute bottom-0 left-0 pl-4 pb-2">Tokyo</h3>
      </div>
    </div>
    <div>
      <div class="relative">
        <%= image_tag "railsui/london.jpg", class: "max-w-full", alt: "London" %>
        <h3 class="md:h3 h4 text-white/95 absolute bottom-0 left-0 pl-4 pb-2">London</h3>
      </div>
    </div>
    <div>
      <div class="relative">
        <%= image_tag "railsui/new-york.jpg", alt: "New York", class: "max-w-full" %>
        <h3 class="md:h3 h4 text-white/95 absolute bottom-0 left-0 pl-4 pb-2">New York</h3>
      </div>
    </div>
    <div>
      <div class="relative">
        <%= image_tag "railsui/los-angeles.jpg", class: "max-w-full", alt: "Los Angeles" %>
        <h3 class="md:h3 h4 text-white/95 absolute bottom-0 left-0 pl-4 pb-2">Los Angeles</h3>
      </div>
    </div>
    <div>
      <div class="relative">
        <%= image_tag "railsui/ireland.jpg", class: "max-w-full", alt: "Ireland" %>
        <h3 class="md:h3 h4 text-white/95 absolute bottom-0 left-0 pl-4 pb-2">Ireland</h3>
      </div>
    </div>
    <div>
      <div class="relative">
        <%= image_tag "railsui/remote.jpg", class: "max-w-full", alt: "Remote" %>
        <h3 class="md:h3 h4 text-white/95 absolute bottom-0 left-0 pl-4 pb-2">Remote</h3>
      </div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto py-6 px-4">
  <div class="gap-8 md:mb-20 mb-6 flex flex-col items-center justify-center text-center md:px-0 px-4">
    <div>
      <blockquote
        class="md:text-xl text-lg font-light text-gray-700/80 leading-8 [text-indent:-14px] max-w-3xl text-center mx-auto dark:text-gray-200">
        &ldquo; Since I've joined Retriever, the pace at which we innovate and provide value continues to suprise me. I don't know of anywhere else I'd rather contribute. &rdquo;
      </blockquote>
    </div>
    <div>
      <%= image_tag "railsui/quote-author-2.png", alt: "Valerie Londell", class: "size-16 inline-block" %>
      <div class="mt-3 block text-base font-semibold text-gray-900 dark:text-gray-400">
        Valerie Londell
      </div>
    </div>
  </div>
</div>

<div class="bg-primary-600/10 text-primary-900 md:py-36 py-16 overflow-hidden dark:text-primary-300">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex md:flex-row flex-col items-start justify-between">
      <div class="md:w-1/2 md:mb-0 mb-10 ">
        <h2 class="h1 mb-6">The security platform <br class="md:block hidden" />
          behind big business</h2>
        <div class="prose prose-lg dark:text-primary-300/80">
          <p>Experience top-tier security with the hosting platform trusted by big businesses. Our cutting-edge security solutions ensure your data is safeguarded, providing peace of mind for your online presence.</p>
          <p>Join the league of successful enterprises relying on our robust security platform. Elevate your hosting experience with us!</p>
        </div>
      </div>
      <div class="md:w-1/2 relative pt-4 md:pl-24 w-full">
        <div class="flex md:flex-row flex-col md:items-start items-center md:justify-between justify-center w-full">
          <div class="relative md:mb-0 mb-6">
            <div
              class="w-[260px] h-[346px] rounded overflow-hidden shadow-xl hover:shadow-2xl transition ease-in-out duration-300">
              <%= link_to "#", class: "absolute inset-x-0 z-10 flex justify-between items-center text-white/90 w-[260px] px-4 pt-3 group hover:text-white transition ease-in-out duration-200" do %>
                <span>Redefining security</span>
                <span>
                  <%= icon "play-circle", class: "stroke-current size-6 text-white/80 group-hover:text-white transition-color
                  ease-in-out duration-200" %>
                </span>
              <% end %>

              <%= link_to "#", class: "absolute inset-x-0 bottom-0 pb-3 px-4 flex items-center gap-2 text-white/90 z-10 group font-medium hover:text-white transition ease-in-out duration-200" do %>
                <span>Watch video</span>
                <%= icon "chevron-right", class: "size-3 relative top-px stroke-current text-white group-hover:translate-x-1
                group-hover:transform transition ease-in-out duration-200" %>
              <% end %>

              <%= image_tag "railsui/callout-1.png", alt: "Callout", class: "rounded w-[260px] h-[346px] absolute inset-0" %>
            </div>
          </div>

          <div class="relative md:mt-16 md:-right-16">
            <div class="w-[260px] h-[346px] rounded overflow-hidden shadow-xl hover:shadow-2xl transition ease-in-out duration-300">
              <%= link_to "#", class: "absolute inset-x-0 bottom-0 pb-3 px-4 flex items-center gap-2 text-white/90 z-10 group font-medium hover:text-white transition ease-in-out duration-200" do %>
                <span>Read case study</span>
                <%= icon "chevron-right", class: "size-3 relative top-px stroke-current text-white group-hover:translate-x-1
                group-hover:transform transition ease-in-out duration-200" %>
              <% end %>

              <%= image_tag "railsui/callout-2.png", class: "rounded w-[260px] h-[346px] absolute inset-0", alt: "Callout 2" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto text-center py-32 px-4">
  <h2 class="h2">Interested in joining us?</h2>
  <div class="prose prose-gray prose-lg dark:prose-invert my-4 mx-auto">
    <p>Join our top-notch team of good people doing good things in harmony.</p>
  </div>
  <%= link_to "#", class: "btn btn-secondary inline-flex items-center justify-center gap-2 dark:btn-primary group" do %>
    <span>Apply now</span>
    <%= icon "chevron-right", class: "size-3 relative top-px stroke-current text-white group-hover:translate-x-px
    group-hover:transform transition ease-in-out duration-200" %>
  <% end %>
</div>

<%= render "rui/shared/footer" %>
