<div class="md:flex mb-6 items-end justify-between">
  <div class="flex-1 md:mb-0 mb-4">
    <h1 class="h2 mb-2">Analytics</h1>
    <p class="text-gray-600 dark:text-gray-400">Showing reports for June 1 – June 11, 2023 (Today)</p>
  </div>
  <div>
    <button type="button" data-controller="railsui-date-range-picker"
      class="btn btn-white space-x-3 flex items-center whitespace-nowrap justify-center font-medium">

      <%= icon "calendar-days", class: "size-5 text-gray-500 dark:text-gray-400 stroke-current" %>
      <span data-railsui-date-range-picker-target="label"></span>
      <input type="hidden" data-railsui-date-range-picker-target="input">
    </button>
  </div>
</div>

<div class="pt-6">
  <%= render "rui/shared/theme/analytics/stats" %>
</div>

<div class="divide-y divide-gray-200/80 dark:divide-gray-700/80">
  <%= render "rui/shared/theme/analytics/mrr" %>
  <%= render "rui/shared/theme/analytics/total_subscribers" %>
</div>
