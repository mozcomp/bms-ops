<%= form_with(model: service, class: "space-y-6") do |form| %>
  <% if service.errors.any? %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <%= icon "exclamation-circle", class: "size-5 text-red-600 dark:text-red-400 flex-shrink-0 mt-0.5" %>
        <div class="flex-1">
          <h3 class="text-sm font-medium text-red-800 dark:text-red-400 mb-2">
            <%= pluralize(service.errors.count, "error") %> prohibited this service from being saved:
          </h3>
          <ul class="list-disc list-inside text-sm text-red-700 dark:text-red-400 space-y-1">
            <% service.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Basic Information</h2>
      <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Essential service details and container configuration</p>
    </div>
    <div class="px-6 py-6 space-y-6">
      <div class="flex items-start gap-6">
        <div class="w-48 flex-shrink-0">
          <%= form.label :name, class: "block text-sm font-medium text-slate-700 dark:text-slate-300" %>
        </div>
        <div class="flex-1 min-w-0">
          <%= form.text_field :name, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500", placeholder: "bms-core-api" %>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Unique service name</p>
        </div>
      </div>

      <div class="flex items-start gap-6">
        <div class="w-48 flex-shrink-0">
          <%= form.label :image, class: "block text-sm font-medium text-slate-700 dark:text-slate-300" %>
        </div>
        <div class="flex-1 min-w-0">
          <%= form.text_field :image, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500 font-mono", placeholder: "bms/core-api" %>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Container image name</p>
        </div>
      </div>

      <div class="flex items-start gap-6">
        <div class="w-48 flex-shrink-0">
          <%= form.label :version, class: "block text-sm font-medium text-slate-700 dark:text-slate-300" %>
        </div>
        <div class="flex-1 min-w-0">
          <%= form.text_field :version, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500 font-mono", placeholder: "v2.4.1 or latest" %>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Image version/tag</p>
        </div>
      </div>

      <div class="flex items-start gap-6">
        <div class="w-48 flex-shrink-0">
          <%= form.label :registry, class: "block text-sm font-medium text-slate-700 dark:text-slate-300" %>
        </div>
        <div class="flex-1 min-w-0">
          <%= form.text_field :registry, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500 font-mono", placeholder: "123456789.dkr.ecr.ap-southeast-2.amazonaws.com" %>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Container registry URL (optional)</p>
        </div>
      </div>

      <div class="flex items-start gap-6">
        <div class="w-48 flex-shrink-0">
          <%= form.label :service_task, class: "block text-sm font-medium text-slate-700 dark:text-slate-300" %>
        </div>
        <div class="flex-1 min-w-0">
          <%= form.text_field :service_task, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500 font-mono", placeholder: "arn:aws:ecs:region:account:task/..." %>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">AWS ECS task ARN (optional)</p>
        </div>
      </div>
    </div>
  </div>

  <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
    <div class="px-6 py-4 border-b border-slate-200 dark:border-slate-700">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">Configuration (JSON)</h2>
      <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Optional JSON configurations for environment, service, and task definitions</p>
    </div>
    <div class="px-6 py-6 space-y-6">
      <div class="flex items-start gap-6">
        <div class="w-48 flex-shrink-0">
          <%= form.label :environment_json, "Environment Variables", class: "block text-sm font-medium text-slate-700 dark:text-slate-300" %>
        </div>
        <div class="flex-1 min-w-0">
          <%= form.text_area :environment_json, rows: 6, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500 font-mono text-sm", placeholder: '{"RAILS_ENV": "production", "DATABASE_URL": "postgres://..."}' %>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">Environment variables as JSON object</p>
        </div>
      </div>

      <div class="flex items-start gap-6">
        <div class="w-48 flex-shrink-0">
          <%= form.label :service_definition_json, "Service Definition", class: "block text-sm font-medium text-slate-700 dark:text-slate-300" %>
        </div>
        <div class="flex-1 min-w-0">
          <%= form.text_area :service_definition_json, rows: 6, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500 font-mono text-sm", placeholder: '{"desiredCount": 1, "launchType": "FARGATE"}' %>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">AWS ECS service definition</p>
        </div>
      </div>

      <div class="flex items-start gap-6">
        <div class="w-48 flex-shrink-0">
          <%= form.label :task_definitions_json, "Task Definitions", class: "block text-sm font-medium text-slate-700 dark:text-slate-300" %>
        </div>
        <div class="flex-1 min-w-0">
          <%= form.text_area :task_definitions_json, rows: 6, class: "form-input w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 focus:border-primary-500 focus:ring-primary-500 font-mono text-sm", placeholder: '{"cpu": "256", "memory": "512"}' %>
          <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">AWS ECS task definition parameters</p>
        </div>
      </div>
    </div>
  </div>

  <div class="flex items-center justify-end gap-3">
    <%= link_to "Cancel", service.persisted? ? service : services_path, class: "btn btn-white" %>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
