<div class="min-h-screen bg-slate-50 dark:bg-slate-900">
  <%= render "shared/sidebar" %>
  
  <div class="lg:ml-64">
    <%= render "shared/topbar" %>
    
    <main class="p-6">
      <!-- Header -->
      <div class="flex items-center justify-between mb-6">
        <div>
          <h1 class="text-2xl font-bold text-slate-800 dark:text-slate-100 mb-2">Services</h1>
          <p class="text-slate-600 dark:text-slate-400">Manage AWS ECS services and deployments</p>
        </div>
        <%= link_to new_service_path, class: "btn btn-primary flex items-center gap-2" do %>
          <%= icon "plus", class: "size-5" %>
          <span>New Service</span>
        <% end %>
      </div>

      <%= render "shared/flash_messages" %>

      <!-- Services Grid -->
      <% if @services.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @services.each do |service| %>
            <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700 overflow-hidden hover:shadow-lg transition">
              <div class="p-6">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div class="size-12 bg-green-100 dark:bg-green-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
                      <%= icon "server", class: "size-6 text-green-600 dark:text-green-400" %>
                    </div>
                    <div class="min-w-0">
                      <h3 class="text-lg font-semibold text-slate-900 dark:text-slate-100 truncate">
                        <%= service.name %>
                      </h3>
                      <span class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium rounded-full bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-300">
                        <span class="size-1.5 bg-green-600 dark:bg-green-400 rounded-full"></span>
                        <%= service.status %>
                      </span>
                    </div>
                  </div>
                </div>

                <div class="space-y-3 mb-4">
                  <div>
                    <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Image</dt>
                    <dd class="text-sm text-slate-900 dark:text-slate-100 font-mono bg-slate-50 dark:bg-slate-900 px-2 py-1 rounded truncate">
                      <%= service.full_image %>
                    </dd>
                  </div>
                  
                  <% if service.service_task.present? %>
                    <div>
                      <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Task ARN</dt>
                      <dd class="text-sm text-slate-600 dark:text-slate-400 truncate">
                        <%= service.service_task %>
                      </dd>
                    </div>
                  <% end %>

                  <div>
                    <dt class="text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Created</dt>
                    <dd class="text-sm text-slate-600 dark:text-slate-400">
                      <%= time_tag service.created_at, service.created_at.strftime("%b %d, %Y") %>
                    </dd>
                  </div>
                </div>

                <div class="flex items-center gap-2 pt-4 border-t border-slate-200 dark:border-slate-700">
                  <%= link_to service, class: "flex-1 btn btn-white text-sm flex items-center justify-center gap-2" do %>
                    <%= icon "eye", class: "size-4" %>
                    <span>View</span>
                  <% end %>
                  <%= link_to edit_service_path(service), class: "flex-1 btn btn-white text-sm flex items-center justify-center gap-2" do %>
                    <%= icon "pencil", class: "size-4" %>
                    <span>Edit</span>
                  <% end %>
                  <%= button_to service, method: :delete, data: { turbo_confirm: "Are you sure you want to delete #{service.name}?" }, class: "btn btn-white text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 text-sm flex items-center justify-center gap-2" do %>
                    <%= icon "trash", class: "size-4" %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="bg-white dark:bg-slate-800 rounded-lg shadow border border-slate-200 dark:border-slate-700">
          <div class="text-center py-12">
            <div class="inline-flex items-center justify-center size-16 bg-slate-100 dark:bg-slate-700 rounded-full mb-4">
              <%= icon "server", class: "size-8 text-slate-400" %>
            </div>
            <h3 class="text-lg font-medium text-slate-900 dark:text-slate-100 mb-2">No services yet</h3>
            <p class="text-slate-600 dark:text-slate-400 mb-6">Get started by creating your first service.</p>
            <%= link_to new_service_path, class: "btn btn-primary inline-flex items-center gap-2" do %>
              <%= icon "plus", class: "size-5" %>
              <span>New Service</span>
            <% end %>
          </div>
        </div>
      <% end %>
    </main>
  </div>
</div>
